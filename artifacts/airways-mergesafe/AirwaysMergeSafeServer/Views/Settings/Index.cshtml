@model AirwaysMergeSafeServer.ViewModels.SettingsViewModel
@{ ViewData["Title"] = "Settings"; ViewBag.Highways = null; }

<div class="mss-page-header">
    <div><h2 class="mss-page-title">Settings</h2><p class="mss-page-sub">Manage highway configurations and API keys</p></div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#hwModal" onclick="openNew()">
        <i class="bi bi-plus me-1"></i>Add Highway
    </button>
</div>

<div class="mss-card mb-4">
    <div class="mss-card-header"><i class="bi bi-key me-1"></i> External API Keys</div>
    <div class="mss-card-body">
        <p class="text-muted small mb-2">TomTom API key for real-time traffic flow in 3D visualization.</p>
        <form method="post" asp-action="SaveTomTomKey" class="d-flex gap-2 align-items-end">
            @Html.AntiForgeryToken()
            <div class="flex-fill">
                <label class="form-label small">TomTom API Key</label>
                <div class="input-group">
                    <input type="password" name="apiKey" id="tomtomKey" class="form-control form-control-sm font-monospace"
                           value="@Model.TomTomApiKey" placeholder="Paste your key…" />
                    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="toggleTomKey()">
                        <i class="bi bi-eye" id="tomkeyIcon"></i>
                    </button>
                </div>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">
                @if (TempData["KeySaved"] != null) { <span><i class="bi bi-check-circle me-1"></i>Saved!</span> }
                else { <span><i class="bi bi-save me-1"></i>Save Key</span> }
            </button>
        </form>
    </div>
</div>

<div class="mss-card mb-4">
    <div class="mss-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-trash3 me-1"></i> Traffic Data Purge Policy</span>
        @if (TempData["PurgeSaved"] != null)
        { <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Saved</span> }
    </div>
    <div class="mss-card-body">
        <div class="small mb-3">
            <p class="text-muted mb-2">
                Removes old rows from the <strong class="text-white">VehicleEvents</strong> table only.
                Both rules run on every purge — a record is deleted when it violates
                <em>either</em> the age limit <em>or</em> the count cap.
            </p>
            <div class="d-flex flex-wrap gap-2 mb-1">
                <span class="badge bg-danger bg-opacity-75" title="Rows in this table are eligible for deletion">
                    <i class="bi bi-trash3 me-1"></i>VehicleEvents — purged
                </span>
            </div>
            <div class="d-flex flex-wrap gap-1">
                @foreach (var tbl in new[]{"Highways","MergeZones","SwitchServers","SensorDevices","TriangulationConfigs","InputFormatConfigs","SamplePayloads","UserProfiles"})
                {
                    <span class="badge bg-success bg-opacity-50" title="Never touched by purge">
                        <i class="bi bi-shield-check me-1"></i>@tbl
                    </span>
                }
            </div>
        </div>

        <form method="post" asp-action="SavePurgeSettings" class="row g-3 mb-3">
            @Html.AntiForgeryToken()
            <div class="col-sm-5">
                <label class="form-label small fw-semibold">Maximum age (days)</label>
                <div class="input-group input-group-sm">
                    <input type="number" name="purgeMaxDays" class="form-control font-monospace"
                           min="1" max="3650" value="@Model.PurgeMaxDays" />
                    <span class="input-group-text text-muted">days</span>
                </div>
                <div class="form-text text-muted" style="font-size:.68rem">
                    Records older than this are deleted on purge.
                </div>
            </div>
            <div class="col-sm-5">
                <label class="form-label small fw-semibold">Maximum record count</label>
                <div class="input-group input-group-sm">
                    <input type="number" name="purgeMaxCount" class="form-control font-monospace"
                           min="100" max="5000000" value="@Model.PurgeMaxCount" />
                    <span class="input-group-text text-muted">records</span>
                </div>
                <div class="form-text text-muted" style="font-size:.68rem">
                    If total exceeds this, oldest records are removed first.
                </div>
            </div>
            <div class="col-sm-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-save me-1"></i>Save
                </button>
            </div>
        </form>

        <div class="d-flex align-items-center gap-3 flex-wrap">
            <form id="purgeForm" style="display:none">@Html.AntiForgeryToken()</form>
            <button class="btn btn-outline-danger btn-sm" onclick="runPurge(this)">
                <i class="bi bi-lightning me-1"></i>Run Purge Now
            </button>
            <span id="purgeResult" class="small text-muted"></span>
        </div>
    </div>
</div>

<div class="mss-card mb-4">
    <div class="mss-card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-speedometer2 me-1"></i> 3D Scene Speed Alerts</span>
        @if (TempData["AlertSaved"] != null)
        { <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Saved</span> }
    </div>
    <div class="mss-card-body">
        <p class="text-muted small mb-3">
            Configure how the <strong class="text-white">Top / Plan</strong> panel in AirScene colors
            vehicle markers by speed tier. Changes take effect on the next AirScene page load.
        </p>
        @{
            var alertRaw = Model.AirSceneAlertsJson;
            var alertObj = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, System.Text.Json.JsonElement>>(alertRaw)
                           ?? new();
            int    sbl        = alertObj.TryGetValue("speedBandLimit",  out var v1) ? v1.GetInt32()    : 5;
            string pat        = alertObj.TryGetValue("defaultPattern",   out var v2) ? v2.GetString()! : "circles";
            bool   pco        = alertObj.TryGetValue("prevColorOverlay", out var v3) && v3.GetBoolean();
            string safeLabel  = alertObj.TryGetValue("safeLabel",        out var v4) ? v4.GetString()! : "Safe Speed";
            string safeColor  = alertObj.TryGetValue("safeColor",        out var v5) ? v5.GetString()! : "#22c55e";
            int    safeBands  = alertObj.TryGetValue("safeBands",        out var v6) ? v6.GetInt32()   : 1;
            string warnLabel  = alertObj.TryGetValue("warningLabel",     out var v7) ? v7.GetString()! : "Warning";
            string warnColor  = alertObj.TryGetValue("warningColor",     out var v8) ? v8.GetString()! : "#f59e0b";
            int    warnBands  = alertObj.TryGetValue("warningBands",     out var v9) ? v9.GetInt32()   : 2;
            string ovLabel    = alertObj.TryGetValue("overspeedLabel",   out var va) ? va.GetString()! : "Overspeed";
            string ovColor    = alertObj.TryGetValue("overspeedColor",   out var vb) ? vb.GetString()! : "#ef4444";
            int    ovBands    = alertObj.TryGetValue("overspeedBands",   out var vc) ? vc.GetInt32()   : 4;
        }
        <form method="post" asp-action="SaveAirSceneAlerts">
            @Html.AntiForgeryToken()
            <div class="row g-3 mb-3">
                <div class="col-sm-4">
                    <label class="form-label small fw-semibold">Speed band limit (mph)</label>
                    <div class="input-group input-group-sm">
                        <input type="number" name="speedBandLimit" class="form-control font-monospace"
                               min="1" max="999" value="@sbl" />
                        <span class="input-group-text text-muted">mph</span>
                    </div>
                    <div class="form-text text-muted" style="font-size:.68rem">Vehicles below this speed are in the Safe tier.</div>
                </div>
                <div class="col-sm-4">
                    <label class="form-label small fw-semibold">Default pattern</label>
                    <select name="defaultPattern" class="form-select form-select-sm">
                        @if (pat == "squares")
                        {
                            <option value="circles">Circles (rings)</option>
                            <option value="squares" selected>Squares (outlines)</option>
                        }
                        else
                        {
                            <option value="circles" selected>Circles (rings)</option>
                            <option value="squares">Squares (outlines)</option>
                        }
                    </select>
                </div>
                <div class="col-sm-4 d-flex align-items-end">
                    <div class="form-check">
                        <input type="checkbox" name="prevColorOverlay" id="pcoChk" class="form-check-input"
                               value="true" @(pco ? "checked" : "") />
                        <label class="form-check-label small" for="pcoChk">Previous color overlay</label>
                        <div class="form-text text-muted" style="font-size:.68rem">Show safe marker underneath warning/overspeed bands.</div>
                    </div>
                </div>
            </div>

            <div class="table-responsive mb-3">
                <table class="table table-dark table-sm mb-0 small">
                    <thead>
                        <tr>
                            <th style="width:22%">Tier</th>
                            <th style="width:30%">Label</th>
                            <th style="width:22%">Color</th>
                            <th style="width:26%">Band count</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><span class="badge" style="background:#22c55e;color:#000">Safe</span></td>
                            <td><input type="text" name="safeLabel" class="form-control form-control-sm" value="@safeLabel" /></td>
                            <td>
                                <div class="d-flex gap-1 align-items-center">
                                    <input type="color" name="safeColor" class="form-control form-control-color form-control-sm" value="@safeColor" style="width:38px;height:30px;padding:2px" />
                                    <code class="small" id="safeColorCode">@safeColor</code>
                                </div>
                            </td>
                            <td><input type="number" name="safeBands" class="form-control form-control-sm font-monospace" min="1" max="10" value="@safeBands" /></td>
                        </tr>
                        <tr>
                            <td><span class="badge" style="background:#f59e0b;color:#000">Warning</span>
                                <div class="text-muted" style="font-size:.65rem">+10–30 mph</div>
                            </td>
                            <td><input type="text" name="warningLabel" class="form-control form-control-sm" value="@warnLabel" /></td>
                            <td>
                                <div class="d-flex gap-1 align-items-center">
                                    <input type="color" name="warningColor" class="form-control form-control-color form-control-sm" value="@warnColor" style="width:38px;height:30px;padding:2px" />
                                    <code class="small" id="warnColorCode">@warnColor</code>
                                </div>
                            </td>
                            <td><input type="number" name="warningBands" class="form-control form-control-sm font-monospace" min="1" max="10" value="@warnBands" /></td>
                        </tr>
                        <tr>
                            <td><span class="badge bg-danger">Overspeed</span>
                                <div class="text-muted" style="font-size:.65rem">+30+ mph</div>
                            </td>
                            <td><input type="text" name="overspeedLabel" class="form-control form-control-sm" value="@ovLabel" /></td>
                            <td>
                                <div class="d-flex gap-1 align-items-center">
                                    <input type="color" name="overspeedColor" class="form-control form-control-color form-control-sm" value="@ovColor" style="width:38px;height:30px;padding:2px" />
                                    <code class="small" id="ovColorCode">@ovColor</code>
                                </div>
                            </td>
                            <td><input type="number" name="overspeedBands" class="form-control form-control-sm font-monospace" min="1" max="10" value="@ovBands" /></td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <button type="submit" class="btn btn-primary btn-sm">
                <i class="bi bi-save me-1"></i>Save Speed Alert Settings
            </button>
        </form>
    </div>
</div>

<div class="mss-card">
    <div class="mss-card-header"><i class="bi bi-sign-intersection me-1"></i> Highways</div>
    <div class="table-responsive">
        <table class="table table-dark table-hover table-sm mb-0">
            <thead><tr><th>Name</th><th>Highway ID</th><th>State</th><th>Description</th><th>Active</th><th></th></tr></thead>
            <tbody>
            @foreach (var h in Model.Highways)
            {
                <tr>
                    <td class="fw-semibold">@h.Name</td>
                    <td class="font-monospace small">@h.HighwayId</td>
                    <td>@h.State</td>
                    <td class="text-muted small">@h.Description</td>
                    <td>@Html.Raw(h.IsActive ? "<span class='text-success'>●</span>" : "<span class='text-muted'>○</span>")</td>
                    <td class="text-end">
                        <button class="btn btn-outline-secondary btn-sm me-1"
                            onclick="openEdit(@h.Id,'@h.Name','@h.HighwayId','@(h.State ?? "")','@(h.Description ?? "")',@h.IsActive.ToString().ToLower())"
                            data-bs-toggle="modal" data-bs-target="#hwModal">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <form method="post" asp-action="Delete" asp-route-id="@h.Id" style="display:inline"
                              onsubmit="return confirm('Delete highway @h.Name?')">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Highways.Any())
            { <tr><td colspan="6" class="text-muted text-center py-4">No highways configured.</td></tr> }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="hwModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content mss-modal">
      <div class="modal-header border-bottom border-secondary">
        <h5 class="modal-title" id="hwModalTitle">Add Highway</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="hwForm" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="hw_id" value="0" />
            <div class="row g-2">
                <div class="col-12"><label class="form-label small">Highway Name *</label><input type="text" name="Name" id="hw_name" class="form-control" required /></div>
                <div class="col-6"><label class="form-label small">Highway ID *</label><input type="text" name="HighwayId" id="hw_hid" class="form-control font-monospace" required /></div>
                <div class="col-6"><label class="form-label small">State / Region</label><input type="text" name="State" id="hw_state" class="form-control" /></div>
                <div class="col-12"><label class="form-label small">Description</label><input type="text" name="Description" id="hw_desc" class="form-control" /></div>
                <div class="col-12">
                    <div class="form-check">
                        <input type="checkbox" name="IsActive" id="hw_active" class="form-check-input" value="true" checked />
                        <label class="form-check-label small" for="hw_active">Active</label>
                    </div>
                </div>
            </div>
        </form>
      </div>
      <div class="modal-footer border-top border-secondary">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary" onclick="document.getElementById('hwForm').submit()">Save</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
function openNew() {
    document.getElementById('hwModalTitle').textContent = 'Add Highway';
    document.getElementById('hwForm').action = '/Settings/Create';
    document.getElementById('hw_id').value = 0;
    ['hw_name','hw_hid','hw_state','hw_desc'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('hw_active').checked = true;
}
function openEdit(id,name,hid,state,desc,active) {
    document.getElementById('hwModalTitle').textContent = 'Edit Highway';
    document.getElementById('hwForm').action = '/Settings/Edit';
    document.getElementById('hw_id').value = id;
    document.getElementById('hw_name').value = name;
    document.getElementById('hw_hid').value = hid;
    document.getElementById('hw_state').value = state;
    document.getElementById('hw_desc').value = desc;
    document.getElementById('hw_active').checked = (active === 'true' || active === true);
}
function toggleTomKey() {
    var i = document.getElementById('tomtomKey');
    var ic = document.getElementById('tomkeyIcon');
    if (i.type==='password'){i.type='text';ic.className='bi bi-eye-slash';}
    else{i.type='password';ic.className='bi bi-eye';}
}

function runPurge(btn) {
    if (!confirm('Run purge now?\n\nOnly VehicleEvents rows matching the age/count policy will be deleted.\n\nAll configuration tables (Highways, MergeZones, SwitchServers, SensorDevices, TriangulationConfigs, InputFormatConfigs, SamplePayloads, UserProfiles) are never touched.')) return;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Purging…';
    var tok = document.querySelector('#purgeForm input[name="__RequestVerificationToken"]').value;
    fetch('/Settings/RunPurge', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'XMLHttpRequest' },
        body: '__RequestVerificationToken=' + encodeURIComponent(tok)
    })
    .then(function(r){ return r.json(); })
    .then(function(d){
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-lightning me-1"></i>Run Purge Now';
        if (d.ok) {
            var res = document.getElementById('purgeResult');
            if (d.totalDeleted === 0) {
                res.innerHTML = '<span class="text-success"><i class="bi bi-check-circle me-1"></i>Nothing to purge — ' + d.remaining + ' records within policy.</span>';
            } else {
                res.innerHTML = '<span class="text-warning"><i class="bi bi-trash me-1"></i>' +
                    'Deleted <strong>' + d.totalDeleted + '</strong> record(s) ' +
                    '(' + d.deletedByAge + ' by age &gt;' + d.maxDays + 'd, ' +
                    d.deletedByCount + ' by count cap ' + d.maxCount.toLocaleString() + '). ' +
                    '<strong>' + d.remaining + '</strong> records remain.</span>';
            }
        }
    })
    .catch(function(e){
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-lightning me-1"></i>Run Purge Now';
        console.error(e);
        document.getElementById('purgeResult').textContent = 'Purge failed — see console.';
    });
}
</script>
}
