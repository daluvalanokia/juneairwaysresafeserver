function clearAirHighlight(vo) {
    if (!vo) return;
    [vo.meshP, vo.meshS, vo.meshT].forEach(function(m) {
        if (!m || !m.material || !m.material.emissive) return;
        m.material.emissive.setHex(0x000000);
        m.material.emissiveIntensity = 0;
    });
}

function applyAirHighlight(vo) {
    if (!vo) return;
    [vo.meshP, vo.meshS, vo.meshT].forEach(function(m) {
        if (!m || !m.material || !m.material.emissive) return;
        m.material.emissive.setHex(0xf59e0b);
        m.material.emissiveIntensity = 0.55;
    });
}

function closeVehicleDetail() {
    clearAirHighlight(selectedAirVehicle);
    selectedAirVehicle = null;
