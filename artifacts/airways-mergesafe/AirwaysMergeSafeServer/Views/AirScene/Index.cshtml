@model AirwaysMergeSafeServer.ViewModels.AirSceneViewModel
@{
    ViewData["Title"] = "3D Air Scene";

    var serversJson = System.Text.Json.JsonSerializer.Serialize(
        Model.SwitchServers
            .Where(s => s.AltitudeMinMeters.HasValue && s.AltitudeMaxMeters.HasValue)
            .Select(s => new {
                serverId   = s.ServerId,
                serverName = s.ServerName,
                zoneId     = s.ZoneId,
                status     = s.Status,
                altMin     = s.AltitudeMinMeters!.Value,
                altMax     = s.AltitudeMaxMeters!.Value,
                altWidth   = s.AltitudeWidthMeters ?? 30.0,
            }));

    var zonesJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Zones.Where(z => z.Latitude.HasValue).Select(z => new {
            zoneId   = z.ZoneId,
            zoneName = z.ZoneName,
            status   = z.Status,
            lat      = z.Latitude,
            lon      = z.Longitude,
            altM     = z.AltitudeMeters ?? 0.0,
            radius   = z.GeofenceRadius,
        }));

    var hw = Model.SelectedHighwayId ?? "";
}

<style>
.air-panel-label {
    position: absolute; top: 7px;
    font-size: 10px; font-weight: 700; letter-spacing: .04em;
    padding: 2px 9px; border-radius: 4px; pointer-events: none; z-index: 5;
}
.air-divider {
    position: absolute; top: 0; bottom: 0;
    width: 2px; background: rgba(255,255,255,0.07); z-index: 4; pointer-events: none;
}
.band-chip {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 10px; border-radius: 6px; font-size: 12px; margin: 3px 3px;
    border: 1px solid rgba(255,255,255,0.10); background: rgba(0,0,0,0.30);
}
.band-swatch { width: 12px; height: 12px; border-radius: 3px; display: inline-block; flex-shrink: 0; }
</style>

<!-- ── Header ──────────────────────────────────────────────────────────── -->
<div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
    <div>
        <h4 class="mb-0">🛫 3D Air Scene</h4>
        <small class="text-muted">Altitude corridor bands · Perspective · Side/Elevation · Top/Plan</small>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <select class="form-select form-select-sm" style="width:180px"
                onchange="location.href='/AirScene?highwayId='+this.value">
            @foreach (var h in Model.Highways)
            {
                @if (h.HighwayId == Model.SelectedHighwayId)
                { <option value="@h.HighwayId" selected>@h.Name</option> }
                else
                { <option value="@h.HighwayId">@h.Name</option> }
            }
        </select>
        <!-- Zone dropdown -->
        <select id="airZoneSel" class="form-select form-select-sm" style="width:160px"
                onchange="airZoneChanged()">
            @foreach (var z in Model.Zones)
            {
                <option value="@z.ZoneId">@z.ZoneName</option>
            }
        </select>
        <!-- Switch Server dropdown -->
        <select id="airServerSel" class="form-select form-select-sm" style="width:180px"
                onchange="airServerChanged()">
            @foreach (var s in Model.SwitchServers)
            {
                <option value="@s.ServerId" data-zone="@(s.ZoneId ?? "")">@s.ServerName</option>
            }
        </select>
        <a href="/Traffic3D" class="btn btn-sm btn-outline-secondary">⬡ Traffic3D</a>
        <!-- Bug Fix 1: Pause/Resume button (ported from MergeSafeServer original) -->
        <button id="btnAnimToggle" class="btn btn-sm btn-outline-warning" onclick="toggleAnimation()">⏸ Pause</button>
        <button class="btn btn-sm btn-outline-success" onclick="doRefresh()">⟳ Live</button>
    </div>
</div>

<!-- ── Sim Data Feed Panel ─────────────────────────────────────────────── -->
<div id="airSimFeedPanel" style="background:rgba(2,5,18,.93);border:1px solid #1e2a4a;border-radius:6px;
     font-family:monospace;font-size:12px;margin-bottom:6px;overflow:hidden">
    <div onclick="toggleAirSimPanel()"
         style="padding:5px 10px;cursor:pointer;display:flex;align-items:center;gap:8px;user-select:none">
        <span style="color:#60a5fa;font-size:.7rem;font-weight:700;letter-spacing:.05em">📡 SIM FEED</span>
        <span id="airSimFeedBadge" style="background:#dc2626;color:#fff;font-size:.6rem;font-weight:700;
              padding:1px 6px;border-radius:9px;letter-spacing:.08em;display:none">● LIVE</span>
        <span id="airSimFeedLine" style="color:#475569;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
            No sim events yet — start the simulator on Data Input Formats.
        </span>
        <span id="airSimFeedToggle" style="color:#60a5fa;font-size:.65rem;flex-shrink:0">▼</span>
    </div>
    <div id="airSimFeedBody" style="max-height:0;overflow:hidden;transition:max-height .25s ease">
        <div style="padding:6px 12px 8px;border-top:1px solid #1e2a4a">
            <table style="width:100%;font-size:.68rem;border-collapse:collapse">
                <tr>
                    <td style="color:#60a5fa;padding:1px 8px 1px 0;width:18%">Vehicle ID</td>
                    <td id="asfVehicleId" style="color:#bfdbfe;width:30%">–</td>
                    <td style="color:#60a5fa;padding:1px 8px;width:12%">Type</td>
                    <td id="asfType" style="color:#bfdbfe">–</td>
                </tr>
                <tr>
                    <td style="color:#60a5fa;padding:1px 8px 1px 0">Alt / Speed</td>
                    <td id="asfAltSpd" style="color:#bfdbfe">–</td>
                    <td style="color:#60a5fa;padding:1px 8px">Zone</td>
                    <td id="asfZone" style="color:#bfdbfe">–</td>
                </tr>
                <tr>
                    <td style="color:#60a5fa;padding:1px 8px 1px 0">Lat / Lon</td>
                    <td id="asfLatLon" colspan="3" style="color:#bfdbfe">–</td>
                </tr>
                <tr>
                    <td style="color:#60a5fa;padding:1px 8px 1px 0">DB Save</td>
                    <td id="asfDbStatus" colspan="3" style="color:#fbbf24">–</td>
                </tr>
            </table>
        </div>
    </div>
</div>

<!-- ── Three-panel canvas (always split) ──────────────────────────────── -->
<div id="sceneWrap" style="position:relative;height:490px;background:#060612;border-radius:8px;overflow:hidden;border:1px solid rgba(255,255,255,0.06)">
    <canvas id="airCanvas" style="width:100%;height:100%;display:block"></canvas>

    <!-- Panel labels -->
    <div class="air-panel-label bg-secondary text-white" style="left:8px">⬡ Perspective</div>
    <div class="air-panel-label bg-info text-dark"       id="lbSide" style="left:43%">↕ Elevation</div>
    <div class="air-panel-label bg-warning text-dark"    id="lbTop"  style="left:72%">⊞ Top / Plan</div>
    <div id="airSimLiveLabel" class="badge bg-success position-absolute"
         style="top:6px;right:8px;font-size:.72rem;opacity:0;transition:opacity .5s ease;pointer-events:none;z-index:10">
        🛰 Live Sim — Vehicle Added
    </div>

    <!-- Dividers -->
    <div class="air-divider" id="divAB" style="left:42%"></div>
    <div class="air-divider" id="divBC" style="left:71%"></div>

    <!-- Altitude Y-axis ticks overlay (side panel area) -->
    <div id="altAxis" style="position:absolute;top:0;bottom:0;left:43%;width:36px;
         font-size:9px;color:rgba(255,255,255,0.32);pointer-events:none;z-index:3;overflow:hidden">
    </div>
</div>

<!-- ── Legend + Inspector ─────────────────────────────────────────────── -->
<div class="row mt-3 g-3">
    <div class="col-lg-8">
        <!-- Altitude band legend -->
        <div class="card border-0 shadow-sm mb-2">
            <div class="card-body py-2 px-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <h6 class="mb-0">📐 Altitude Band Corridors</h6>
                    <div class="d-flex gap-3 small text-muted">
                        <span>Air: <b id="stAir">@Model.AirCount</b></span>
                        <span>AirFlyCar: <b>@Model.GroundCount</b></span>
                        <span>Zones: <b>@Model.Zones.Count</b></span>
                        <span>Corridors: <b id="stBands">–</b></span>
                        <span class="text-muted" id="stTime"></span>
                    </div>
                </div>
                <div id="bandLegend" class="d-flex flex-wrap">
                    <span class="text-muted small">Loading corridor data…</span>
                </div>
            </div>
        </div>
        <!-- Vehicle category key -->
        <div class="card border-0 shadow-sm">
            <div class="card-body py-2 px-3">
                <h6 class="mb-1">🔑 Vehicle Categories</h6>
                <div class="d-flex flex-wrap gap-1">
                    @{
                        // AirScene is air-only — ground vehicle categories not shown here
                        var cats = new[]{
                            ("air_urban",  "#00bcd4", "✈"),
                            ("air_express","#ff6b35", "🛩"),
                        };
                    }
                    @foreach (var (cat, col, icon) in cats)
                    {
                        var cnt = Model.CategoryBreakdown.TryGetValue(cat, out var c) ? c : 0;
                        <span class="badge rounded-pill px-3 py-1"
                              style="background:@col;color:#fff;font-size:.65rem">
                            @icon @cat@(cnt > 0 ? $" ({cnt})" : "")
                        </span>
                    }
                    <span class="badge rounded-pill px-3 py-1 ms-1"
                          style="background:#ef4444;font-size:.65rem">⚠ conflict</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body py-2 px-3">
                <h6 class="mb-1">🔍 Inspector <small class="text-muted">(click vehicle)</small></h6>
                <div id="airInspector" class="text-muted small">
                    Click any vehicle across any panel to inspect it.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
/* ══════════════════════════════════════════════════════════════════════
   AirwaysMergeSafe — 3D AIR SCENE  (Task 10: standalone controller/view)
   Always-split three-panel: Perspective (42%) | Side/Elevation (28%) | Top/Plan (28%)
   Bug fixes applied:
     Fix 1: btnAnimToggle / toggleAnimation / onSimStateChange ported from original
     Fix 2: BroadcastChannel handler filters by type (no longer flips Pause↔Resume
             on every sim_vehicle message)
     Fix 3: 30-second auto-refresh gated by animationPaused
     Fix 4: airways_sim_active lifecycle key gets its own separate storage listener
   ══════════════════════════════════════════════════════════════════════ */

const ALT_SCALE = 0.05;
const XZ_SCALE  = 800;
const HW        = '@hw';

const SERVERS = @Html.Raw(serversJson);
const ZONES   = @Html.Raw(zonesJson);
const ALERT   = @Html.Raw(Model.AirSceneAlertsJson);

// ── Zone / Server dropdown state ──────────────────────────────────────
var selectedZoneId   = (function(){
    var sel = document.getElementById('airZoneSel');
    return sel && sel.options.length ? sel.options[0].value : '';
})();
var selectedServerId = (function(){
    var opts = document.querySelectorAll('#airServerSel option');
    if (!opts.length) return '';
    for (var i=0;i<opts.length;i++){
        if (opts[i].dataset.zone === selectedZoneId) { opts[i].selected = true; return opts[i].value; }
    }
    return opts[0].value;
})();

function airZoneChanged() {
    selectedZoneId = document.getElementById('airZoneSel').value;
    var srvSel = document.getElementById('airServerSel');
    var all    = srvSel.querySelectorAll('option');
    var first  = '';
    all.forEach(function(o){
        var match = !selectedZoneId || o.dataset.zone === selectedZoneId;
        o.style.display = match ? '' : 'none';
        if (match && !first) { first = o.value; }
    });
    srvSel.value = first;
    selectedServerId = first;
    airHighlightCorridors();
    airZoomToVehicles(function(vo){ return vo.ev.zoneId === selectedZoneId; });
}

function airServerChanged() {
    selectedServerId = document.getElementById('airServerSel').value;
    airHighlightCorridors();
    airZoomToVehicles(function(vo){
        var b = findBand(vo.ev.altitudeMeters);
        return b && b.server.serverId === selectedServerId;
    });
}

function airHighlightCorridors() {
    if (!window._corridorMeshes) return;
    window._corridorMeshes.forEach(function(obj){
        var isSel = !selectedServerId || obj.serverId === selectedServerId;
        obj.mesh.material.opacity = isSel ? 0.22 : 0.06;
        obj.mesh.material.wireframe = isSel;
    });
}

function airZoomToVehicles(matchFn) {
    if (!vehicleObjects || !vehicleObjects.length) return;
    var matched = vehicleObjects.filter(matchFn);
    if (!matched.length) return;
    var avgY = matched.reduce(function(s, vo){ return s + vo.altY; }, 0) / matched.length;
    var startR = radius, startLY = lookTarget.y;
    var targR  = Math.max(45, startR * 0.18);
    var targLY = Math.max(5, avgY);
    var frames = 0, phase = 'in';
    var FIN = 70, FHOLD = 130, FOUT = 85;
    airCamTween = function() {
        var t, ease;
        if (phase === 'in') {
            frames++;
            t = Math.min(1, frames / FIN);
            ease = t < 0.5 ? 2*t*t : -1+(4-2*t)*t;
            radius       = startR  + (targR  - startR)  * ease;
            lookTarget.y = startLY + (targLY - startLY) * ease;
            if (frames >= FIN) { frames = 0; phase = 'hold'; }
        } else if (phase === 'hold') {
            frames++;
            if (frames >= FHOLD) { frames = 0; phase = 'out'; }
        } else {
            frames++;
            t = Math.min(1, frames / FOUT);
            ease = t < 0.5 ? 2*t*t : -1+(4-2*t)*t;
            radius       = targR  + (startR  - targR)  * ease;
            lookTarget.y = targLY + (startLY - targLY) * ease;
            if (frames >= FOUT) { airCamTween = null; radius = startR; lookTarget.y = startLY; }
        }
    };
}

function bandHsl(i) { return `hsl(${(i * 137.508) % 360}, 68%, 55%)`; }
function bandColor(i) { return new THREE.Color(bandHsl(i)); }

// Air Scene is air-only — ground vehicle categories are NOT rendered here.
const CAT = {
    air_urban:   { color:'#00bcd4', icon:'✈',  domain:'air',
        geoP: ()=>new THREE.ConeGeometry(0.55, 0.9, 6),
        geoT: ()=>new THREE.CircleGeometry(0.9, 16),
        geoS: ()=>new THREE.CircleGeometry(0.5, 12) },
    air_express: { color:'#ff6b35', icon:'🛩', domain:'air',
        geoP: ()=>new THREE.OctahedronGeometry(0.65),
        geoT: ()=>{ const g=new THREE.CircleGeometry(0.7,4); g.rotateZ(Math.PI/4); return g; },
        geoS: ()=>new THREE.CircleGeometry(0.55, 4) },
};
const CAT_DEFAULT = CAT.air_urban;
function getSpec(cat) { return CAT[cat] || CAT_DEFAULT; }

// AirScene: all events are air-domain. No ground fallback — controller pre-filters.
function resolveClass(ev) {
    if (ev.vehicleClassJson) {
        try {
            const vc = typeof ev.vehicleClassJson === 'string'
                ? JSON.parse(ev.vehicleClassJson) : ev.vehicleClassJson;
            if (vc && vc.category && (vc.domain === 'air' || ev.isAirFlyCar === 'Y'))
                return { ...vc, domain: 'air' };
        } catch(e) {}
    }
    // IsAirFlyCar="Y" takes precedence
    if (ev.isAirFlyCar === 'Y')
        return { category: 'air_urban', domain: 'air', color: '#00bcd4', confidence: 0.85 };
    // Classify by altitude (all events here are air-domain)
    const alt = ev.altitudeMeters;
    if (alt != null && alt > 150)
        return { category: 'air_express', domain: 'air', color: '#ff6b35', confidence: 0.65 };
    return { category: 'air_urban', domain: 'air', color: '#00bcd4', confidence: 0.5 };
}

function findBand(altM) {
    if (altM == null) return null;
    for (let i = 0; i < SERVERS.length; i++) {
        const s = SERVERS[i];
        if (altM >= s.altMin && altM <= s.altMax) return { server: s, idx: i };
    }
    return null;
}

let midLat = 32.75, midLon = -97.0;
function norm(lat, lon) { return { x: (lon - midLon) * XZ_SCALE, z: (lat - midLat) * XZ_SCALE }; }

// ── Three.js scene ────────────────────────────────────────────────────
const canvas   = document.getElementById('airCanvas');
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
renderer.setPixelRatio(window.devicePixelRatio);
renderer.setSize(canvas.clientWidth, canvas.clientHeight);

const scene = new THREE.Scene();
scene.background = new THREE.Color(0x060612);
scene.add(new THREE.AmbientLight(0xffffff, 0.45));
const sun = new THREE.DirectionalLight(0xffffff, 0.85);
sun.position.set(80, 200, 100); scene.add(sun);
scene.add(new THREE.GridHelper(500, 40, 0x1a1a3a, 0x111128));

[50, 100, 150, 200, 250, 300, 350, 400].forEach(altM => {
    const m = new THREE.Mesh(
        new THREE.PlaneGeometry(420, 420),
        new THREE.MeshBasicMaterial({ color: 0x1e3a5f, transparent: true, opacity: 0.035,
                                      depthWrite: false, side: THREE.DoubleSide })
    );
    m.rotation.x = Math.PI / 2;
    m.position.y = altM * ALT_SCALE;
    scene.add(m);
});

const NUM_BANDS   = SERVERS.length;
const CORRIDOR_Z  = 300;
const CORRIDOR_SEP = 14;

window._corridorMeshes = [];

SERVERS.forEach((s, i) => {
    const h    = Math.max(1, (s.altMax - s.altMin)) * ALT_SCALE;
    const midY = (s.altMin + s.altMax) / 2 * ALT_SCALE;
    const w    = Math.max(5, s.altWidth) * ALT_SCALE * 7;
    const xOff = (i - (NUM_BANDS - 1) / 2) * (w + CORRIDOR_SEP);
    const col  = bandColor(i);

    const fillGeo = new THREE.BoxGeometry(w, h, CORRIDOR_Z);
    const fillMat = new THREE.MeshPhongMaterial({
        color: col, transparent: true, opacity: 0.13, depthWrite: false
    });
    const fill = new THREE.Mesh(fillGeo, fillMat);
    fill.position.set(xOff, midY, 0);
    scene.add(fill);
    window._corridorMeshes.push({ serverId: s.serverId, zoneId: s.zoneId, mesh: fill });

    const edgeMat = new THREE.LineBasicMaterial({ color: col, opacity: 0.55, transparent: true });
    const edges   = new THREE.LineSegments(new THREE.EdgesGeometry(fillGeo), edgeMat);
    edges.position.copy(fill.position);
    scene.add(edges);

    const mkLine = (y, op) => {
        const geo = new THREE.BufferGeometry().setFromPoints([
            new THREE.Vector3(-200, y, 0), new THREE.Vector3(200, y, 0)
        ]);
        const line = new THREE.Line(geo,
            new THREE.LineBasicMaterial({ color: col, opacity: op, transparent: true }));
        scene.add(line);
    };
    mkLine(s.altMax * ALT_SCALE, 0.60);
    mkLine(s.altMin * ALT_SCALE, 0.35);
});

ZONES.forEach(z => {
    if (!z.lat || !z.lon) return;
    const p = norm(z.lat, z.lon);
    const r = (z.radius / 20) || 12;
    const cy = new THREE.Mesh(
        new THREE.CylinderGeometry(r, r, 0.15, 32),
        new THREE.MeshPhongMaterial({
            color: z.status === 'active' ? 0x22c55e : 0xf59e0b, transparent: true, opacity: 0.18
        })
    );
    cy.position.set(p.x, 0.08 + z.altM * ALT_SCALE, p.z);
    scene.add(cy);
    const ring = new THREE.Mesh(
        new THREE.TorusGeometry(r, 0.12, 8, 48),
        new THREE.MeshPhongMaterial({ color: 0x22c55e, opacity: 0.40, transparent: true })
    );
    ring.rotation.x = Math.PI / 2;
    ring.position.set(p.x, 0.2, p.z);
    scene.add(ring);
});

// ── Cameras ────────────────────────────────────────────────────────────
const camP = new THREE.PerspectiveCamera(55, 1, 0.1, 3000);
camP.position.set(120, 110, 220);
camP.lookAt(0, 35, 0);

const OW = 180, OH = 140;
const camS = new THREE.OrthographicCamera(-OW, OW, OH, -OH, 0.1, 2000);
camS.position.set(500, 0, 0); camS.lookAt(0, 0, 0);

const camT = new THREE.OrthographicCamera(-OW, OW, OH, -OH, 0.1, 2000);
camT.position.set(0, 600, 0);
camT.up.set(0, 0, -1); camT.lookAt(0, 0, 0);

camP.layers.enable(1);
camS.layers.enable(2);
camT.layers.enable(3);

// ── Vehicle objects ───────────────────────────────────────────────────
const vehicleObjects = [];
const conflictRings  = [];
const raycaster = new THREE.Raycaster(), mouse2 = new THREE.Vector2();
let selectedAirVehicle = null;

function buildVehicle(ev) {
    const vc    = resolveClass(ev);
    const sp    = getSpec(vc.category);
    const isAir = vc.domain === 'air';
    const altY  = isAir ? (ev.altitudeMeters || 60) * ALT_SCALE : 0.3;
    const topY  = isAir ? altY : 0.15;
    const col   = vc.conflictFlag ? '#ef4444' : (vc.color || sp.color);
    const c3    = new THREE.Color(col);

    const p = (ev.latitude && ev.longitude)
        ? norm(ev.latitude, ev.longitude)
        : { x: (Math.random() - 0.5) * 160, z: (Math.random() - 0.5) * 160 };

    const ud = { ev, vc, baseY: altY };

    const meshP = new THREE.Mesh(sp.geoP(),
        new THREE.MeshPhongMaterial({ color: c3, side: THREE.DoubleSide }));
    meshP.position.set(p.x, altY, p.z);
    if (isAir) meshP.rotation.y = Math.random() * Math.PI * 2;
    meshP.userData = ud;
    meshP.layers.set(1);

    const meshS = new THREE.Mesh(sp.geoS(),
        new THREE.MeshPhongMaterial({ color: c3, side: THREE.DoubleSide }));
    meshS.position.set(p.x, altY, p.z);
    meshS.rotation.y = Math.PI / 2;
    meshS.userData = ud;
    meshS.layers.set(2);

    const meshT = new THREE.Mesh(sp.geoT(),
        new THREE.MeshPhongMaterial({ color: c3, side: THREE.DoubleSide }));
    meshT.position.set(p.x, topY, p.z);
    meshT.rotation.x = -Math.PI / 2;
    meshT.userData = { ev, vc, baseY: topY };
    meshT.layers.set(3);

    return { meshP, meshS, meshT, p, isAir, altY, topY, ev, vc };
}

function buildSpeedOverlay(ev, p, isAir, altY) {
    const overlays = [];
    const speed    = ev.speedMph  || 0;
    const limit    = +(ALERT.speedBandLimit  ?? 5);
    const delta    = speed - limit;
    const pat      = ALERT.defaultPattern    || 'circles';
    const useOvl   = ALERT.prevColorOverlay  !== false;

    let color, numBands, showPattern;
    if (delta < 0) {
        color       = ALERT.safeColor      || '#22c55e';
        numBands    = +(ALERT.safeBands    || 1);
        showPattern = false;
    } else if (delta < 10) {
        color       = ALERT.safeColor      || '#22c55e';
        numBands    = +(ALERT.safeBands    || 1);
        showPattern = true;
    } else if (delta < 30) {
        color       = ALERT.warningColor   || '#f59e0b';
        numBands    = +(ALERT.warningBands || 2);
        showPattern = true;
    } else {
        color       = ALERT.overspeedColor  || '#ef4444';
        numBands    = +(ALERT.overspeedBands || 4);
        showPattern = true;
    }

    const baseY = isAir ? altY - 0.2 : 0.06;
    const c3    = new THREE.Color(color);

    const baseGeo = pat === 'circles'
        ? new THREE.CircleGeometry(1.8, 16)
        : new THREE.PlaneGeometry(3.2, 3.2);
    const baseMesh = new THREE.Mesh(baseGeo, new THREE.MeshBasicMaterial({
        color: c3, transparent: true, opacity: 0.42,
        side: THREE.DoubleSide, depthWrite: false
    }));
    baseMesh.rotation.x = -Math.PI / 2;
    baseMesh.position.set(p.x, baseY, p.z);
    baseMesh.layers.set(3);
    overlays.push(baseMesh);

    if (showPattern) {
        for (let b = 0; b < numBands; b++) {
            const r   = 2.4 + b * 2.0;
            const opc = Math.max(0.15, 0.55 - b * 0.08);
            if (pat === 'circles') {
                const geo = new THREE.TorusGeometry(r, 0.28, 6, 32);
                const m = new THREE.Mesh(geo, new THREE.MeshBasicMaterial({
                    color: c3, transparent: true, opacity: opc, depthWrite: false
                }));
                m.position.set(p.x, baseY + 0.06 * (b + 1), p.z);
                m.rotation.x = -Math.PI / 2;
                m.layers.set(3);
                overlays.push(m);
            } else {
                const geo = new THREE.EdgesGeometry(new THREE.BoxGeometry(r * 2, 0.05, r * 2));
                const m = new THREE.LineSegments(geo, new THREE.LineBasicMaterial({
                    color: c3, transparent: true, opacity: opc
                }));
                m.position.set(p.x, baseY + 0.06 * (b + 1), p.z);
                m.layers.set(3);
                overlays.push(m);
            }
        }
        if (useOvl && delta >= 10) {
            const sc3 = new THREE.Color(ALERT.safeColor || '#22c55e');
            const og = pat === 'circles'
                ? new THREE.CircleGeometry(1.2, 16)
                : new THREE.PlaneGeometry(2.0, 2.0);
            const om = new THREE.Mesh(og, new THREE.MeshBasicMaterial({
                color: sc3, transparent: true, opacity: 0.22,
                side: THREE.DoubleSide, depthWrite: false
            }));
            om.rotation.x = -Math.PI / 2;
            om.position.set(p.x, baseY - 0.05, p.z);
            om.layers.set(3);
            overlays.push(om);
        }
    }
    return overlays;
}

function buildConflictRing(pos) {
    const ring = new THREE.Mesh(
        new THREE.TorusGeometry(2.0, 0.18, 8, 32),
        new THREE.MeshPhongMaterial({ color: 0xef4444, transparent: true, opacity: 0.75 })
    );
    ring.rotation.x = Math.PI / 2;
    ring.position.copy(pos);
    return ring;
}

function clearScene() {
    vehicleObjects.forEach(vo => {
        [vo.meshP, vo.meshS, vo.meshT].forEach(m => {
            scene.remove(m); m.geometry.dispose(); m.material.dispose();
        });
        vo.overlays.forEach(m => {
            scene.remove(m); m.geometry.dispose();
            if (m.material && m.material.dispose) m.material.dispose();
        });
    });
    vehicleObjects.length = 0;
    conflictRings.forEach(m => {
        scene.remove(m); m.geometry.dispose(); m.material.dispose();
    });
    conflictRings.length = 0;
}

function loadEvents(evs) {
    clearScene();
    const lats = evs.filter(e => e.latitude).map(e => e.latitude);
    const lons = evs.filter(e => e.longitude).map(e => e.longitude);
    if (lats.length) {
        midLat = lats.reduce((a,b) => a + b, 0) / lats.length;
        midLon = lons.reduce((a,b) => a + b, 0) / lons.length;
    }

    // Air Scene: controller already filtered to air-only — all events rendered as air
    let stA = 0;
    evs.forEach(ev => {
        const vc = resolveClass(ev);

        const vo       = buildVehicle(ev);
        const overlays = buildSpeedOverlay(ev, vo.p, vo.isAir, vo.altY);
        vo.overlays    = overlays;

        scene.add(vo.meshP);
        scene.add(vo.meshS);
        scene.add(vo.meshT);
        overlays.forEach(m => scene.add(m));
        vehicleObjects.push(vo);

        if (vc.conflictFlag) {
            const ring = buildConflictRing(vo.meshP.position);
            scene.add(ring); conflictRings.push(ring);
        }
        stA++;
    });

    document.getElementById('stAir').textContent  = stA;
    document.getElementById('stTime').textContent = 'Updated ' + new Date().toLocaleTimeString();
}

async function doRefresh() {
    try {
        const r = await fetch(`/api/events/live?highwayId=${HW}&take=140&mode=air`);
        if (!r.ok) return;
        loadEvents(await r.json());
    } catch(e) { console.warn('AirScene refresh error:', e); }
}

// ── Click-to-inspect ──────────────────────────────────────────────────
const SPLIT = [0, 0.42, 0.71, 1.00];

canvas.addEventListener('click', e => {
    var panel = document.getElementById('vehicleDetailPanel');
    if (panel && panel.contains(e.target)) return;
    const rect = canvas.getBoundingClientRect();
    const rx   = (e.clientX - rect.left) / rect.width;
    const ry   = (e.clientY - rect.top)  / rect.height;

    let cam, lx, pickArr;
    if      (rx < SPLIT[1]) { cam = camP; lx = rx / SPLIT[1];                     pickArr = vehicleObjects.map(vo => vo.meshP); }
    else if (rx < SPLIT[2]) { cam = camS; lx = (rx-SPLIT[1])/(SPLIT[2]-SPLIT[1]); pickArr = vehicleObjects.map(vo => vo.meshS); }
    else                     { cam = camT; lx = (rx-SPLIT[2])/(SPLIT[3]-SPLIT[2]); pickArr = vehicleObjects.map(vo => vo.meshT); }

    mouse2.x =  lx * 2 - 1;
    mouse2.y = -ry * 2 + 1;
    raycaster.setFromCamera(mouse2, cam);
    const hits = raycaster.intersectObjects(pickArr, false);
    if (!hits.length) { closeVehicleDetail(); return; }
    const hitMesh = hits[0].object;
    const vo = vehicleObjects.find(o => o.meshP === hitMesh || o.meshS === hitMesh || o.meshT === hitMesh);
    if (!vo) { closeVehicleDetail(); return; }
    if (selectedAirVehicle && selectedAirVehicle !== vo) clearAirHighlight(selectedAirVehicle);
    selectedAirVehicle = vo;
    applyAirHighlight(vo);
    showVehicleDetail(hitMesh.userData, e.clientX, e.clientY);
    showInspector(hitMesh.userData);
});

