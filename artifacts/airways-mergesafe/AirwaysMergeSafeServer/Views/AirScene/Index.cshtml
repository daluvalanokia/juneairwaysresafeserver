// ── Orbit control ─────────────────────────────────────────────────────
let isDrag = false, prevM = {x:0,y:0}, theta = 0.6, phi = 0.5, radius = 310;
let airCamTween = null;
var lookTarget = { y: 15 };

canvas.addEventListener('mousemove', e => {
    if (isDrag) return;
    const rect = canvas.getBoundingClientRect();
    const rx   = (e.clientX - rect.left) / rect.width;
    const ry   = (e.clientY - rect.top)  / rect.height;
    let cam, lx, pickArr;
    if      (rx < SPLIT[1]) { cam = camP; lx = rx / SPLIT[1];                     pickArr = vehicleObjects.map(vo => vo.meshP); }
    else if (rx < SPLIT[2]) { cam = camS; lx = (rx-SPLIT[1])/(SPLIT[2]-SPLIT[1]); pickArr = vehicleObjects.map(vo => vo.meshS); }
    else                     { cam = camT; lx = (rx-SPLIT[2])/(SPLIT[3]-SPLIT[2]); pickArr = vehicleObjects.map(vo => vo.meshT); }
    mouse2.x =  lx * 2 - 1;
    mouse2.y = -ry * 2 + 1;
    raycaster.setFromCamera(mouse2, cam);
    canvas.style.cursor = raycaster.intersectObjects(pickArr, false).length ? 'pointer' : '';
});

canvas.addEventListener('mousedown', e => {
    const rect = canvas.getBoundingClientRect();
    const rx   = (e.clientX - rect.left) / rect.width;
    if (rx < SPLIT[1]) { isDrag = true; prevM = {x: e.clientX, y: e.clientY}; }
});
window.addEventListener('mouseup',   () => isDrag = false);
window.addEventListener('mousemove', e => {
    if (!isDrag) return;
    theta -= (e.clientX - prevM.x) * 0.005;
    phi    = Math.max(0.05, Math.min(1.45, phi - (e.clientY - prevM.y) * 0.005));
    prevM  = {x: e.clientX, y: e.clientY};
});
canvas.addEventListener('wheel', e => {
    radius = Math.max(60, Math.min(900, radius + e.deltaY * 0.25));
});

