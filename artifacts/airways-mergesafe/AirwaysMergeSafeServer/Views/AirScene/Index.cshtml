      <tr><td class="text-muted">Category</td>
          <td><span class="badge" style="background:${vc.color||'#64748b'}">${vc.category}</span></td></tr>
      ${pct > 0 ? `<tr><td class="text-muted">Confidence</td><td>
          <div class="d-flex align-items-center gap-2">
            <div class="progress flex-grow-1" style="height:5px">
              <div class="progress-bar bg-${confCls}" style="width:${pct}%"></div>
            </div><small>${pct}%</small></div></td></tr>` : ''}
      <tr><td class="text-muted">Altitude</td>
          <td><b>${altM != null ? altM.toFixed(1) + ' m' : 'ground level'}</b></td></tr>
      <tr><td class="text-muted">Speed</td>
          <td>${ev.speedMph != null ? ev.speedMph.toFixed(1) + ' mph' : '—'}</td></tr>
      <tr><td class="text-muted">Event</td>
          <td>${ev.eventType || '—'}</td></tr>
      <tr><td class="text-muted">Zone</td>
          <td>${ev.zoneId || '—'}</td></tr>
      <tr><td class="text-muted">Corridor</td>
          <td>${bandHtml}</td></tr>
      ${ph  ? `<tr><td class="text-muted">Flight phase</td>
               <td><span class="badge bg-secondary">${ph}</span></td></tr>` : ''}
      ${soc != null ? `<tr><td class="text-muted">Battery SOC</td><td>
          <div class="d-flex align-items-center gap-1">
            <div class="progress flex-grow-1" style="height:5px">
              <div class="progress-bar bg-${soc<25?'danger':soc<50?'warning':'success'}"
