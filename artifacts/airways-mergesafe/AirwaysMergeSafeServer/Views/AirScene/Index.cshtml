function renderAltAxis() {
    const el = document.getElementById('altAxis');
    const wrap  = document.getElementById('sceneWrap');
    const maxAlt = SERVERS.length ? Math.max(...SERVERS.map(s => s.altMax)) : 400;
    const ticks  = [0, 50, 100, 150, 200, 250, 300, 350, 400].filter(t => t <= maxAlt + 80);
    const ch     = wrap.clientHeight;
    el.innerHTML = ticks.map(t => {
        const sceneY = t * ALT_SCALE;
        const frac   = 0.5 - sceneY / (OH * 2);
        const py     = Math.round(frac * ch);
        return `<div style="position:absolute;top:${py}px;right:2px;white-space:nowrap">${t} m</div>`;
    }).join('');
}

// ── Feed-mode Pause/Resume (Fix 1: full implementation) ───────────────
// Pausing stops live data injection AND 30-second polling (feed-mode control).
// onSimStateChange handles both sim-started and sim-stopped lifecycle events.
// Initial state is synced from localStorage on page load.
let tick = 0;
let animationPaused = false;

// State machine:
//   animationPaused=false → live mode   (button "⏸ Pause",   30s polling ON,  sim injections blocked)
//   animationPaused=true  → sim-only mode (button "▶ Resume", 30s polling OFF, sim injections allowed)
function toggleAnimation() {
    animationPaused = !animationPaused;
    var btn = document.getElementById('btnAnimToggle');
    if (btn) btn.textContent = animationPaused ? '▶ Resume' : '⏸ Pause';
    if (!animationPaused) doRefresh(); // returning to live mode → load fresh live data
}

// ── Air Sim Data Feed Panel JS ─────────────────────────────────────────
var _airSimPanelOpen = false;
function toggleAirSimPanel() {
    _airSimPanelOpen = !_airSimPanelOpen;
    var body = document.getElementById('airSimFeedBody');
    var tog  = document.getElementById('airSimFeedToggle');
    if (body) body.style.maxHeight = _airSimPanelOpen ? '90px' : '0';
    if (tog)  tog.textContent = _airSimPanelOpen ? '▲' : '▼';
}
function _updateAirSimPanel(ev, dbStatus) {
    var t   = new Date().toLocaleTimeString('en-US', {hour12:false});
    var spd = (ev.speedMph ?? 0).toFixed(1);
    var alt = (ev.altitudeMeters ?? 0).toFixed(0);
    var lat = (ev.latitude  ?? 0).toFixed(4);
    var lon = (ev.longitude ?? 0).toFixed(4);
    var line = t + '  ·  ' + (ev.vehicleId||'?') + '  ·  '
             + (ev.vehicleCategory || 'air') + '  ·  ' + alt + ' m · ' + spd + ' mph';
    var el = document.getElementById('airSimFeedLine');
    if (el) { el.style.color = '#bfdbfe'; el.textContent = line;
              setTimeout(function(){ el.style.color = '#93c5fd'; }, 800); }
    function setEl(id, val) { var x = document.getElementById(id); if (x) x.textContent = val || '–'; }
    setEl('asfVehicleId', ev.vehicleId);
    setEl('asfType',      ev.vehicleCategory || 'air');
    setEl('asfAltSpd',   alt + ' m · ' + spd + ' mph');
    setEl('asfZone',      ev.zoneId || '–');
    setEl('asfLatLon',    lat + ', ' + lon);
    if (dbStatus !== undefined) {
        var dbEl = document.getElementById('asfDbStatus');
        if (dbEl) { dbEl.textContent = dbStatus;
                    dbEl.style.color = dbStatus.startsWith('✓') ? '#4ade80' : '#fbbf24'; }
    }
    if (!_airSimPanelOpen) toggleAirSimPanel();
    var badge = document.getElementById('airSimFeedBadge');
    if (badge) badge.style.display = '';
}

function onSimStateChange(isRunning) {
    animationPaused = isRunning;
    var btn = document.getElementById('btnAnimToggle');
    if (btn) btn.textContent = isRunning ? '▶ Resume' : '⏸ Pause';
    var badge = document.getElementById('airSimFeedBadge');
    if (badge) badge.style.display = isRunning ? '' : 'none';
    if (!isRunning) {
        doRefresh();
        if (_airSimPanelOpen) toggleAirSimPanel();
        var el = document.getElementById('airSimFeedLine');
        if (el) { el.style.color = '#475569'; el.textContent = 'Sim stopped — viewing live data.'; }
    }
}

// ── Animate loop ──────────────────────────────────────────────────────
function animate() {
    requestAnimationFrame(animate);
    tick++;
    if (airCamTween) airCamTween();

    camP.position.x = radius * Math.sin(theta) * Math.cos(phi);
    camP.position.y = Math.max(5, radius * Math.sin(phi));
    camP.position.z = radius * Math.cos(theta) * Math.cos(phi);
    camP.lookAt(0, lookTarget.y, 0);

    // Bug Fix 3 (partial): vehicle animation gated by animationPaused
    if (!animationPaused) {
        vehicleObjects.forEach((vo, i) => {
            if (vo.vc.domain === 'air') {
                const dy = Math.sin(tick * 0.025 + i * 0.8) * 1.2;
                vo.meshP.position.y = vo.altY + dy;
                vo.meshS.position.y = vo.altY + dy;
                vo.meshT.position.y = vo.topY + dy;
                vo.meshP.rotation.y += 0.006;
                vo.meshT.rotation.z += 0.006;
                const oy = vo.topY + dy - 0.2;
                vo.overlays.forEach(m => { m.position.y = oy; });
            } else {
                const dy = Math.sin(tick * 0.04 + i) * 0.05;
                vo.meshP.position.y = vo.altY + dy;
                vo.meshS.position.y = vo.altY + dy;
                vo.meshT.position.y = vo.topY + dy;
            }
        });
        conflictRings.forEach((r, i) => {
            if (vehicleObjects[i]) r.position.y = vehicleObjects[i].meshP.position.y;
            r.rotation.z += 0.02;
        });
    }

    const cw = canvas.clientWidth, ch = canvas.clientHeight;
    renderer.setSize(cw, ch, false);

    renderer.setViewport(0,       0, cw * 0.42, ch);
    renderer.setScissor( 0,       0, cw * 0.42, ch);
    renderer.setScissorTest(true);
    camP.aspect = (cw * 0.42) / ch;
    camP.updateProjectionMatrix();
    renderer.render(scene, camP);

    renderer.setViewport(cw * 0.43, 0, cw * 0.27, ch);
    renderer.setScissor( cw * 0.43, 0, cw * 0.27, ch);
    renderer.render(scene, camS);

    renderer.setViewport(cw * 0.72, 0, cw * 0.27, ch);
    renderer.setScissor( cw * 0.72, 0, cw * 0.27, ch);
    renderer.render(scene, camT);

    renderer.setScissorTest(false);
}

// ── Boot ──────────────────────────────────────────────────────────────
(async () => {
    renderBandLegend();
    renderAltAxis();
    await doRefresh();
    animate();
})();

// Fix 3: Gate 30-second auto-refresh when animation is paused
setInterval(function() { if (!animationPaused) doRefresh(); }, 30000);
window.addEventListener('resize', renderAltAxis);
// Restore sim feed state from localStorage on page load (handles DataInputFormats navigation)
(function() { if (localStorage.getItem('airways_sim_active') === 'true') onSimStateChange(true); })();

// ── Live simulation feed ───────────────────────────────────────────────
function _airNorm(evObj, cl) {
    var ev = Object.assign({}, evObj);
    if (cl) {
        ev.vehicleCategory  = cl.category;
        ev.vehicleMode      = cl.domain;
        ev.altitudeMeters   = (cl.altitudeM  != null) ? cl.altitudeM  : (evObj.altitude_m  ?? 0);
        ev.speedMph         = (cl.speedMph   != null) ? cl.speedMph   : (evObj.speed_mph   ?? 0);
        ev.vehicleClassJson = JSON.stringify(cl);
    } else {
        ev.altitudeMeters = evObj.altitude_m  ?? 0;
        ev.speedMph       = evObj.speed_mph   ?? 0;
    }
    ev.latitude  = evObj.latitude  ?? evObj.lat  ?? 32.7767;
    ev.longitude = evObj.longitude ?? evObj.lon  ?? -96.7970;
    ev.vehicleId = evObj.vehicle_id || ('SIM-' + Math.random().toString(36).slice(2,6).toUpperCase());
    ev.eventType = evObj.event_type || 'detection';
    ev.zoneId    = evObj.zone_id    || '';
    return ev;
}

function _airInject(evObj, cl) {
    var ev = _airNorm(evObj, cl);

    _updateAirSimPanel(ev, '⏳ saving…');

    // ── Always save to DB + refresh (works in both live and sim-only modes) ──
    fetch('/api/sim/event', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            vehicleId:      ev.vehicleId,
            highwayId:      HW || '',
            zoneId:         ev.zoneId || selectedZoneId || '',
            vehicleType:    ev.vehicleCategory || 'air_urban',
            srcType:        'airflycar',
            isAirFlyCar:    'Y',
            speedMph:       ev.speedMph,
            latitude:       ev.latitude,
            longitude:      ev.longitude,
            altitudeMeters: ev.altitudeMeters ?? 0
        })
    }).then(function(r) {
        return r.json().then(function(j) {
            if (r.ok) { _updateAirSimPanel(ev, '✓ saved · id ' + j.id); doRefresh(); }
            else       { _updateAirSimPanel(ev, '✗ ' + (j.error || r.status)); }
        });
    }).catch(function(err) {
        _updateAirSimPanel(ev, '✗ ' + (err.message || 'network error'));
        _airInjectDirect(ev, cl); // fallback: direct inject
    });

    var lbl = document.getElementById('airSimLiveLabel');
    if (lbl) { lbl.style.opacity = '1'; setTimeout(function(){ lbl.style.opacity = '0'; }, 2500); }
    document.getElementById('stTime').textContent = 'Sim · ' + new Date().toLocaleTimeString();

    if (!animationPaused) return; // camera tween only in sim-only mode
    var startR = radius, startP = phi;
    var targR  = Math.max(25, startR * 0.13);
    var targP  = Math.max(0.15, Math.min(0.55, startP));
    var frames = 0, phase = 'in';
    var FIN = 55, FHOLD = 100, FOUT = 70;
    airCamTween = function() {
        var t, ease;
        if (phase === 'in') {
            frames++;
            t = Math.min(1, frames / FIN);
            ease = t < 0.5 ? 2*t*t : -1+(4-2*t)*t;
            radius = startR + (targR - startR) * ease;
            phi    = startP + (targP - startP) * ease;
            if (frames >= FIN) { frames = 0; phase = 'hold'; }
        } else if (phase === 'hold') {
            frames++;
            if (frames >= FHOLD) { frames = 0; phase = 'out'; }
        } else {
            frames++;
            t = Math.min(1, frames / FOUT);
            ease = t < 0.5 ? 2*t*t : -1+(4-2*t)*t;
            radius = targR + (startR - targR) * ease;
            phi    = targP + (startP - targP) * ease;
            if (frames >= FOUT) { airCamTween = null; radius = startR; phi = startP; }
        }
    };
}

function _airInjectDirect(ev, cl) {
    var vc = resolveClass(ev);
    var vo = buildVehicle(ev);
    var overlays = buildSpeedOverlay(ev, vo.p, vo.isAir, vo.altY);
    vo.overlays = overlays;
    scene.add(vo.meshP); scene.add(vo.meshS); scene.add(vo.meshT);
    overlays.forEach(function(m){ scene.add(m); });
    vehicleObjects.push(vo);
    var aEl = document.getElementById('stAir');
    if (aEl) aEl.textContent = (+aEl.textContent||0) + 1;
}

// Bug Fix 2: BroadcastChannel — only call onSimStateChange for lifecycle events.
// Previously, onSimStateChange(e.data.type === 'sim_started') was called for ALL
// messages, toggling Pause↔Resume on every sim_vehicle post interval.
if (typeof BroadcastChannel !== 'undefined') {
    var _airSimBc = new BroadcastChannel('airways_sim');
    _airSimBc.onmessage = function(e) {
        if (!e.data) return;
        if (e.data.type === 'sim_vehicle' && e.data.payload)
            _airInject(e.data.payload, e.data.classification);
        if (e.data.type === 'sim_started') {
            if (!animationPaused) doRefresh();
            onSimStateChange(true);
        }
        if (e.data.type === 'sim_stopped') onSimStateChange(false);
    };
}

// Bug Fix 4: Separate storage listeners — airways_sim_active handles lifecycle state;
// airways_sim_last_event handles vehicle payloads only (no dead sim_started check).
window.addEventListener('storage', function(e) {
    if (e.key === 'airways_sim_active') { onSimStateChange(e.newValue === 'true'); return; }
    if (e.key !== 'airways_sim_last_event' || !e.newValue) return;
    try {
        var msg = JSON.parse(e.newValue);
        if (msg.type === 'sim_vehicle' && msg.payload)
            _airInject(msg.payload, msg.classification);
    } catch(ex) {}
});
</script>
}
