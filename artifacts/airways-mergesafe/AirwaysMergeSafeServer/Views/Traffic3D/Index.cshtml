    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body py-2 px-3">
                <h6 class="mb-1">🔍 Inspector <small class="text-muted">(click vehicle)</small></h6>
                <div id="inspector" class="text-muted small">No vehicle selected.</div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
/* ══════════════════════════════════════════════════════════════════════
   GROUND-ONLY 3D TRAFFIC SCENE  (Task 10 rewrite)
   Air vehicles are shown in the dedicated Air Scene (/AirScene).
   Bug fixes: Pause/Resume, BroadcastChannel filter, gated interval,
              separate storage listener for airways_sim_active.
   ══════════════════════════════════════════════════════════════════════ */

const ALT_SCALE = 0.05;
const XZ_SCALE  = 800;
const HW        = '@hw';

// ── Zone / Server dropdown state ──────────────────────────────────────
const T3D_SERVERS = @Html.Raw(serversJson);
const T3D_ZONES   = @Html.Raw(zonesJson);
var selectedZoneId   = '';
var selectedServerId = '';

function t3dZoneChanged() {
    selectedZoneId = document.getElementById('t3dZoneSel').value;
    var srvSel = document.getElementById('t3dServerSel');
    srvSel.querySelectorAll('option').forEach(function(o) {
        var show = !selectedZoneId || !o.dataset.zone || o.dataset.zone === selectedZoneId;
        o.style.display = show ? '' : 'none';
        if (!show && srvSel.value === o.value) { srvSel.value = ''; selectedServerId = ''; }
    });
    var z = T3D_ZONES.find(function(zz){ return zz.zoneId === selectedZoneId; });
    if (z && z.lat && z.lon) _reloadMapTile(z.lat, z.lon);
    refreshScene();
}

function t3dServerChanged() {
    selectedServerId = document.getElementById('t3dServerSel').value;
    var opt = document.querySelector('#t3dServerSel option[value="' + selectedServerId + '"]');
    if (opt && opt.dataset.zone && !selectedZoneId) {
        document.getElementById('t3dZoneSel').value = opt.dataset.zone;
        selectedZoneId = opt.dataset.zone;
    }
    refreshScene();
}

// ── OSM tile helpers (navigation map background) ─────────────────────
function _latLonToTile(lat, lon, z) {
    var n = 1 << z;
    var x = Math.floor((lon + 180) / 360 * n);
    var sinLat = Math.sin(lat * Math.PI / 180);
    var y = Math.floor((1 - Math.log((sinLat + 1) / Math.cos(lat * Math.PI / 180)) / Math.PI) / 2 * n);
    return { x: x, y: y, z: z };
}
var _mapTileLat = @Html.Raw(zoneCtrLat.ToString("0.0000", System.Globalization.CultureInfo.InvariantCulture));
var _mapTileLon = @Html.Raw(zoneCtrLon.ToString("0.0000", System.Globalization.CultureInfo.InvariantCulture));
var _mapTileLoading = false;

function _reloadMapTile(lat, lon) {
    _mapTileLat = lat; _mapTileLon = lon; _mapTileLoading = false; _tryLoadMapTile();
}

function _tryLoadMapTile() {
    if (_mapTileLoading) return;
    _mapTileLoading = true;
    var t = _latLonToTile(_mapTileLat, _mapTileLon, 14);
    var url = 'https://tile.openstreetmap.org/' + t.z + '/' + t.x + '/' + t.y + '.png';
    var loader = new THREE.TextureLoader();
    loader.crossOrigin = 'anonymous';
    loader.load(url, function(tex) {
        tex.wrapS = tex.wrapT = THREE.ClampToEdgeWrapping;
        if (window._t3dGround) {
            window._t3dGround.material.map   = tex;
            window._t3dGround.material.color.setHex(0xddeedd); // light tint over map
            window._t3dGround.material.needsUpdate = true;
        }
    }, undefined, function() { /* CORS blocked — keep terrain fallback */ });
}

// ── Ground vehicle geometry + colour factory ──────────────────────────
const CAT_SPEC = {
    sedan:       { color:'#3b82f6', geo:()=>new THREE.BoxGeometry(1.6,0.4,0.8) },
    suv:         { color:'#22c55e', geo:()=>new THREE.BoxGeometry(1.9,0.55,0.9) },
    truck:       { color:'#f59e0b', geo:()=>new THREE.BoxGeometry(2.4,0.75,0.95) },
    motorcycle:  { color:'#a855f7', geo:()=>new THREE.CylinderGeometry(0.15,0.15,0.5,8) },
    van:         { color:'#64748b', geo:()=>new THREE.BoxGeometry(2.1,1.0,1.0) },
};
const DEFAULT_SPEC = CAT_SPEC.sedan;

function getSpec(vc) {
    if (!vc) return DEFAULT_SPEC;
    const cat = vc.category || vc.vehicleCategory || 'sedan';
    return CAT_SPEC[cat] || DEFAULT_SPEC;
}

// ── JS-side ground classifier ─────────────────────────────────────────
function classifyLocal(ev) {
    if (ev.vehicleClassJson) {
        try {
            const vc = typeof ev.vehicleClassJson === 'string'
                ? JSON.parse(ev.vehicleClassJson) : ev.vehicleClassJson;
            if (vc && vc.category && vc.domain === 'ground') return vc;
        } catch(e) {}
    }
    if (ev.vehicleCategory && ev.vehicleMode === 'ground')
        return { category: ev.vehicleCategory, domain: 'ground',
                 color: CAT_SPEC[ev.vehicleCategory]?.color || '#3b82f6' };

    // Speed heuristic — ground only
    const s = ev.speedMph;
    let cat = 'sedan';
    if (s !== null && s !== undefined) {
        if (s <= 25)      cat = 'motorcycle';
        else if (s <= 55) cat = 'sedan';
        else if (s <= 75) cat = 'suv';
        else if (s <= 90) cat = 'truck';
        else              cat = 'van';
    }
    return { category: cat, domain: 'ground', color: CAT_SPEC[cat]?.color || '#3b82f6' };
}

// ── Lat/lon normalisation ─────────────────────────────────────────────
let midLat = 32.75, midLon = -97.0;
function norm(lat, lon) {
    return { x: (lon - midLon) * XZ_SCALE, z: (lat - midLat) * XZ_SCALE };
}

// ── Scene setup ───────────────────────────────────────────────────────
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x1a2f1a); // dark terrain green — ground environment
scene.fog = new THREE.Fog(0x1a2f1a, 600, 1200);
scene.add(new THREE.AmbientLight(0xffffff, 0.7));
const dir = new THREE.DirectionalLight(0xffffff, 1.1);
dir.position.set(0, 300, 80); scene.add(dir);
const sunLight = new THREE.DirectionalLight(0xfff4cc, 0.5);
sunLight.position.set(-100, 200, -200); scene.add(sunLight);

// ── Ground terrain ────────────────────────────────────────────────────
const groundGeo = new THREE.PlaneGeometry(1400, 1400);
const groundMat = new THREE.MeshPhongMaterial({ color: 0x1e3a1e }); // green terrain
const ground = new THREE.Mesh(groundGeo, groundMat);
ground.rotation.x = -Math.PI / 2; ground.position.y = -0.1;
scene.add(ground);
window._t3dGround = ground; // exposed for OSM tile loader

// ── Asphalt road surface (highway running along X axis) ───────────────
const roadW = 72; // total road width (4 lanes × ~18 units each)
const roadGeo = new THREE.PlaneGeometry(1400, roadW);
const roadMat = new THREE.MeshPhongMaterial({ color: 0x374151 }); // asphalt
const road = new THREE.Mesh(roadGeo, roadMat);
road.rotation.x = -Math.PI / 2; road.position.y = 0.0;
scene.add(road);

// Road shoulders (concrete-grey border strips)
[-roadW/2 - 5, roadW/2 + 5].forEach(oz => {
    const sg = new THREE.PlaneGeometry(1400, 10);
    const sm = new THREE.MeshPhongMaterial({ color: 0x4b5563 });
    const sh = new THREE.Mesh(sg, sm);
    sh.rotation.x = -Math.PI / 2; sh.position.set(0, 0, oz);
    scene.add(sh);
});

// Outer edge white lines
[-roadW/2, roadW/2].forEach(oz => {
    const eg = new THREE.PlaneGeometry(1400, 1.2);
    const em = new THREE.MeshPhongMaterial({ color: 0xffffff });
    const el = new THREE.Mesh(eg, em);
    el.rotation.x = -Math.PI / 2; el.position.set(0, 0.02, oz);
    scene.add(el);
});

// Yellow center divider (double line)
[-0.9, 0.9].forEach(oz => {
    const cg = new THREE.PlaneGeometry(1400, 0.7);
    const cm2 = new THREE.MeshPhongMaterial({ color: 0xfbbf24 });
    const cl2 = new THREE.Mesh(cg, cm2);
    cl2.rotation.x = -Math.PI / 2; cl2.position.set(0, 0.02, oz);
    scene.add(cl2);
});

// Dashed white lane dividers between lanes
const laneOffsets = [-18, 18]; // between inner and outer lanes each side
laneOffsets.forEach(oz => {
    for (let x = -680; x < 700; x += 28) {
        const dg = new THREE.PlaneGeometry(14, 0.6);
        const dm = new THREE.MeshPhongMaterial({ color: 0xffffff });
        const dash = new THREE.Mesh(dg, dm);
        dash.rotation.x = -Math.PI / 2; dash.position.set(x, 0.02, oz);
        scene.add(dash);
    }
});

// Roadside trees (simple green cylinders on terrain)
for (let x = -650; x <= 650; x += 60) {
    [-50, 50].forEach(oz => {
        const tg = new THREE.CylinderGeometry(3, 4, 12, 8);
        const tm = new THREE.MeshPhongMaterial({ color: 0x166534 });
        const tree = new THREE.Mesh(tg, tm);
        tree.position.set(x + (Math.random()-0.5)*10, 6, oz + (Math.random()-0.5)*5);
        scene.add(tree);
    });
}

// Static zone markers (road-surface rings only — no tall cylinders)
const ZONES = @Html.Raw(zonesJson);
ZONES.forEach(z => {
    if (!z.lat || !z.lon) return;
    const p  = norm(z.lat, z.lon);
    const r  = (z.radius / 20) || 15;
    const ring = new THREE.Mesh(
        new THREE.TorusGeometry(r, 0.4, 8, 48),
        new THREE.MeshPhongMaterial({ color: z.status === 'active' ? 0x22c55e : 0xf59e0b,
                                      opacity: 0.8, transparent: true })
    );
    ring.rotation.x = Math.PI / 2;
    ring.position.set(p.x, 0.3, p.z);
    scene.add(ring);
});

// ── Vehicle mesh management ───────────────────────────────────────────
const vehicleMeshes = [], vehicleData = [];
const vehicleMap    = new Map();   // vehicleId → mesh  (enables live upsert by vehicle)
const raycaster = new THREE.Raycaster();
const mouse2    = new THREE.Vector2();
let selectedVehicleMesh = null;

// Lane centre Z positions (4 lanes: 2 eastbound, 2 westbound)
const LANE_Z = [-27, -9, 9, 27];

function buildVehicleMesh(ev) {
    const vc   = classifyLocal(ev);
    const spec = getSpec(vc);
    const geo  = spec.geo();
    const mat  = new THREE.MeshPhongMaterial({ color: new THREE.Color(vc.color || spec.color) });
    const mesh = new THREE.Mesh(geo, mat);

    // Snap to a road lane centre; keep x from GPS if available
    const p = (ev.latitude && ev.longitude) ? norm(ev.latitude, ev.longitude)
              : { x: (Math.random()-0.5)*400, z: 0 };
    const laneZ = LANE_Z[vehicleMap.size % LANE_Z.length];
    mesh.position.set(p.x, 0.35, laneZ);

    // Heading-based velocity: eastbound lanes (z<0) go +x, westbound (z>0) go -x
    const headingDeg = ev.heading ?? (laneZ < 0 ? 90 : 270);
    const headingRad = headingDeg * Math.PI / 180;
    // Speed in scene-units/frame at 60fps (mph → scene units)
    const speedFactor = ((ev.speedMph ?? 55) * 0.018);
    const vx =  Math.sin(headingRad) * speedFactor;
    const vz = -Math.cos(headingRad) * speedFactor;

    mesh.rotation.y = headingRad; // face the direction of travel
    mesh.userData = { ev, vc, baseY: 0.35, idx: vehicleMeshes.length, vx, vz, laneZ };
    return mesh;
}

function loadEvents(events) {
    const seenIds = new Set();
    const lats = [], lons = [];

    events.forEach(ev => {
        const vc = classifyLocal(ev);
        if (vc.domain !== 'ground') return;
        const vid = ev.vehicleId || (ev.id != null ? 'db-' + ev.id : null);
        if (!vid) return;

        seenIds.add(vid);
        if (ev.latitude)  lats.push(ev.latitude);
        if (ev.longitude) lons.push(ev.longitude);

        if (vehicleMap.has(vid)) {
            // ── Update existing vehicle's speed/heading ───────────────
            const mesh = vehicleMap.get(vid);
            mesh.userData.ev = ev;
            const headingDeg = ev.heading ?? (mesh.userData.laneZ < 0 ? 90 : 270);
            const headingRad = headingDeg * Math.PI / 180;
            const spd = ((ev.speedMph ?? 55) * 0.018);
            mesh.userData.vx = Math.sin(headingRad) * spd;
            mesh.userData.vz = -Math.cos(headingRad) * spd;
            mesh.rotation.y  = headingRad;
        } else {
            // ── Add new vehicle mesh ──────────────────────────────────
            const mesh = buildVehicleMesh(ev);
            scene.add(mesh);
            vehicleMeshes.push(mesh);
            vehicleMap.set(vid, mesh);
            vehicleData.push({ ev, vc });
        }
    });

    // Remove stale vehicles no longer in the live feed
    vehicleMap.forEach((mesh, vid) => {
        if (!seenIds.has(vid)) {
            scene.remove(mesh); mesh.geometry.dispose(); mesh.material.dispose();
            vehicleMap.delete(vid);
            const idx = vehicleMeshes.indexOf(mesh);
            if (idx >= 0) vehicleMeshes.splice(idx, 1);
        }
    });

    if (lats.length) {
        midLat = lats.reduce((a,b)=>a+b,0)/lats.length;
        midLon = lons.reduce((a,b)=>a+b,0)/lons.length;
        _tryLoadMapTile(); // re-centre map tile on actual vehicle cluster
    }
    document.getElementById('statGround').textContent = vehicleMap.size;
}

async function refreshScene() {
    try {
        const zq = selectedZoneId ? `&zoneId=${encodeURIComponent(selectedZoneId)}` : '';
        const r = await fetch(`/api/events/live?highwayId=${HW}&take=100&mode=ground${zq}`);
        if (!r.ok) return;
        loadEvents(await r.json());
    } catch(e) { console.warn('Scene refresh error:', e); }
}

// ── Camera setup ──────────────────────────────────────────────────────
const canvas = document.getElementById('mainCanvas');
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
renderer.setPixelRatio(window.devicePixelRatio);
renderer.setSize(canvas.clientWidth, canvas.clientHeight);

// Perspective — looking down the highway at a shallow road-level angle
const camP = new THREE.PerspectiveCamera(55, canvas.clientWidth/canvas.clientHeight, 0.1, 3000);
camP.position.set(-220, 55, 120); camP.lookAt(60, 0, 0);

// Side elevation (road cross-section)
const oW = 240, oH = 90;
const camS = new THREE.OrthographicCamera(-oW, oW, oH, -oH, 0.1, 2000);
camS.position.set(0, 0, 500); camS.lookAt(0, 0, 0);

// Top-down (traffic-management bird's-eye view — DEFAULT)
const oTW = 300, oTH = 120;
const camT = new THREE.OrthographicCamera(-oTW, oTW, oTH, -oTH, 0.1, 2000);
camT.position.set(0, 600, 0); camT.up.set(1, 0, 0); camT.lookAt(0, 0, 0);

// ── View mode ─────────────────────────────────────────────────────────
let currentView = 'perspective';

function setViewport(view) {
    currentView = view;
    const w = renderer.domElement.clientWidth;
    document.getElementById('labelA').style.display = view === 'split' ? '' : 'none';
    document.getElementById('labelB').style.display = view === 'split' ? '' : 'none';
    document.getElementById('labelC').style.display = view === 'split' ? '' : 'none';
    if (view === 'split') {
        document.getElementById('labelB').style.left = Math.round(w * 0.43) + 'px';
        document.getElementById('labelC').style.left = Math.round(w * 0.72) + 'px';
    }
}

// ── Orbit (perspective) ───────────────────────────────────────────────
let isDrag = false, prevM = {x:0,y:0}, theta = 0.6, phi = 0.5, radius = 280;
canvas.addEventListener('mousedown', e => { isDrag = true; prevM = {x:e.clientX, y:e.clientY}; });
window.addEventListener('mouseup', () => isDrag = false);
window.addEventListener('mousemove', e => {
    if (!isDrag || currentView !== 'perspective') return;
    theta -= (e.clientX - prevM.x) * 0.005;
    phi    = Math.max(0.05, Math.min(1.4, phi - (e.clientY - prevM.y) * 0.005));
    prevM  = { x: e.clientX, y: e.clientY };
});
canvas.addEventListener('wheel', e => { radius = Math.max(60, Math.min(700, radius + e.deltaY * 0.25)); });

canvas.addEventListener('mousemove', e => {
    if (isDrag) return;
    const rect = canvas.getBoundingClientRect();
    mouse2.x =  ((e.clientX - rect.left) / rect.width)  * 2 - 1;
    mouse2.y = -((e.clientY - rect.top)  / rect.height) * 2 + 1;
    let cam = camP;
    if (currentView === 'side') cam = camS;
    else if (currentView === 'top') cam = camT;
    raycaster.setFromCamera(mouse2, cam);
    canvas.style.cursor = raycaster.intersectObjects(vehicleMeshes, false).length ? 'pointer' : '';
});

// ── Click — vehicle inspector ─────────────────────────────────────────
canvas.addEventListener('click', e => {
    var panel = document.getElementById('vehicleDetailPanel');
    if (panel && panel.contains(e.target)) return;
    const rect = canvas.getBoundingClientRect();
    mouse2.x =  ((e.clientX - rect.left) / rect.width)  * 2 - 1;
    mouse2.y = -((e.clientY - rect.top)  / rect.height) * 2 + 1;

    let cam = camP;
    if (currentView === 'side') cam = camS;
    else if (currentView === 'top') cam = camT;
    else if (currentView === 'split') {
        const rx = (e.clientX - rect.left) / rect.width;
        cam = rx < 0.42 ? camP : rx < 0.71 ? camS : camT;
    }

    raycaster.setFromCamera(mouse2, cam);
    const hits = raycaster.intersectObjects(vehicleMeshes, false);
    if (!hits.length) { closeVehicleDetail(); return; }
    const mesh = hits[0].object;
    if (selectedVehicleMesh && selectedVehicleMesh !== mesh) clearVehicleHighlight(selectedVehicleMesh);
    selectedVehicleMesh = mesh;
    if (mesh.material && mesh.material.emissive) {
        mesh.material.emissive.setHex(0xf59e0b);
        mesh.material.emissiveIntensity = 0.55;
    }
    showVehicleDetail(mesh.userData, e.clientX, e.clientY);
    showInspector(mesh.userData);
});

function showInspector({ ev, vc }) {
    const conf    = vc.confidence ?? vc.Confidence ?? 0;
    const confPct = Math.round(conf * 100);
    const confCls = conf < 0.4 ? 'danger' : conf < 0.65 ? 'warning' : 'success';
    document.getElementById('inspector').innerHTML = `
    <table class="table table-sm table-borderless mb-0 small">
      <tr><td class="text-muted">Vehicle ID</td><td><b>${ev.vehicleId||'—'}</b></td></tr>
      <tr><td class="text-muted">Category</td><td>
        <span class="badge" style="background:${vc.color||'#64748b'}">${vc.category}</span>
      </td></tr>
      <tr><td class="text-muted">Confidence</td><td>
        <div class="d-flex align-items-center gap-2">
          <div class="progress flex-grow-1" style="height:6px">
            <div class="progress-bar bg-${confCls}" style="width:${confPct}%"></div>
          </div>
          <small>${confPct}%</small>
        </div>
        ${conf < 0.4 ? '<small class="text-danger">⚠ low confidence</small>' : ''}
      </td></tr>
      <tr><td class="text-muted">Speed</td><td>${ev.speedMph!=null?ev.speedMph.toFixed(1)+' mph':'—'}</td></tr>
      <tr><td class="text-muted">Event</td><td>${ev.eventType||'—'}</td></tr>
      <tr><td class="text-muted">Zone</td><td>${ev.zoneId||'—'}</td></tr>
    </table>`;
}

function clearVehicleHighlight(mesh) {
    if (!mesh || !mesh.material || !mesh.material.emissive) return;
    mesh.material.emissive.setHex(0x000000);
    mesh.material.emissiveIntensity = 0;
}

function closeVehicleDetail() {
    clearVehicleHighlight(selectedVehicleMesh);
    selectedVehicleMesh = null;
    var panel = document.getElementById('vehicleDetailPanel');
    if (panel) panel.style.display = 'none';
}

function vdSwitchTab(tab) {
    document.getElementById('vdBodyFmt').style.display = tab === 'fmt' ? '' : 'none';
    document.getElementById('vdBodyRaw').style.display = tab === 'raw' ? '' : 'none';
    document.getElementById('vdTabFmt').style.background = tab === 'fmt' ? 'rgba(59,130,246,.18)' : 'transparent';
    document.getElementById('vdTabRaw').style.background = tab === 'raw' ? 'rgba(59,130,246,.18)' : 'transparent';
    document.getElementById('vdTabFmt').style.color = tab === 'fmt' ? '#60a5fa' : '#64748b';
    document.getElementById('vdTabRaw').style.color = tab === 'raw' ? '#60a5fa' : '#64748b';
}

function showVehicleDetail({ ev, vc }, cx, cy) {
    var wrap  = document.getElementById('sceneWrap');
    var panel = document.getElementById('vehicleDetailPanel');
    if (!wrap || !panel) return;

    var conf     = (vc.confidence ?? vc.Confidence ?? 0);
    var confPct  = Math.round(conf * 100);
    var confClr  = conf < 0.4 ? '#ef4444' : conf < 0.65 ? '#f59e0b' : '#22c55e';
    var srcBadge = (ev && ev.vehicleId)
        ? '<span style="background:#22c55e;color:#000;padding:1px 6px;border-radius:3px;font-size:.62rem;font-weight:700;margin-left:4px">LIVE</span>'
        : '<span style="background:#475569;color:#fff;padding:1px 6px;border-radius:3px;font-size:.62rem;font-weight:700;margin-left:4px">AMBIENT</span>';

    document.getElementById('vdTitle').innerHTML = '🚗 ' + (vc.category || 'Vehicle') + srcBadge;

    var confBar = '<div style="display:flex;align-items:center;gap:5px">'
        + '<div style="flex:1;height:4px;background:rgba(255,255,255,.12);border-radius:2px">'
        + '<div style="width:' + confPct + '%;height:4px;background:' + confClr + ';border-radius:2px"></div></div>'
        + '<span style="font-size:.68rem;color:#cbd5e1">' + confPct + '%</span></div>';

    var rows = [
        ['Vehicle ID', (ev && ev.vehicleId) || '—'],
        ['Category',   '<span style="background:' + (vc.color||'#64748b') + ';color:#fff;padding:1px 6px;border-radius:3px;font-size:.68rem">' + vc.category + '</span>'],
        ['Confidence', confPct > 0 ? confBar : '—'],
        ['Speed',      ev && ev.speedMph != null ? ev.speedMph.toFixed(1) + ' mph' : '—'],
        ['Event',      (ev && ev.eventType) || '—'],
        ['Zone',       (ev && ev.zoneId)    || '—'],
    ];
    document.getElementById('vdBodyFmt').innerHTML =
        '<table style="width:100%;border-collapse:collapse;font-size:.72rem">' +
        rows.map(function(r) {
            return '<tr><td style="color:#64748b;padding:3px 0;width:40%;vertical-align:top">' + r[0] + '</td>'
                 + '<td style="color:#e2e8f0;padding:3px 0 3px 8px">' + r[1] + '</td></tr>';
        }).join('') + '</table>';

    document.getElementById('vdRawPre').textContent = JSON.stringify({ ev: ev, vc: vc }, null, 2);
    vdSwitchTab('fmt');

    var wrapRect = wrap.getBoundingClientRect();
    var panW = 304, panH = 240;
    var px = cx - wrapRect.left + 12;
    var py = cy - wrapRect.top  + 12;
    if (px + panW > wrapRect.width)  px = cx - wrapRect.left - panW - 4;
    if (py + panH > wrapRect.height) py = cy - wrapRect.top  - panH - 4;
    panel.style.left    = Math.max(0, px) + 'px';
    panel.style.top     = Math.max(0, py) + 'px';
    panel.style.display = '';
}

(function() {
    var wrap = document.getElementById('sceneWrap');
    if (!wrap) return;
    var p = document.createElement('div');
    p.id = 'vehicleDetailPanel';
    p.style.cssText =
        'display:none;position:absolute;top:0;left:0;z-index:20;width:300px;' +
        'background:rgba(8,12,24,.97);border:1px solid rgba(255,255,255,.14);' +
        'border-radius:10px;backdrop-filter:blur(8px);' +
        'box-shadow:0 8px 32px rgba(0,0,0,.6);overflow:hidden;';
    p.innerHTML =
        '<div style="padding:9px 12px;border-bottom:1px solid rgba(255,255,255,.09);' +
            'display:flex;justify-content:space-between;align-items:center">' +
            '<span id="vdTitle" style="font-size:.8rem;font-weight:700;color:#e2e8f0;' +
                'white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:230px"></span>' +
            '<button onclick="closeVehicleDetail()" style="background:none;border:none;color:#94a3b8;' +
                'font-size:1.1rem;cursor:pointer;line-height:1;padding:0 2px;flex-shrink:0">&#215;</button>' +
        '</div>' +
        '<div style="display:flex;border-bottom:1px solid rgba(255,255,255,.07)">' +
            '<button id="vdTabFmt" onclick="vdSwitchTab(\'fmt\')" ' +
                'style="flex:1;padding:5px;font-size:.7rem;font-weight:600;' +
                'background:rgba(59,130,246,.18);border:none;color:#60a5fa;cursor:pointer">Formatted</button>' +
            '<button id="vdTabRaw" onclick="vdSwitchTab(\'raw\')" ' +
