// ── View mode toggle ──────────────────────────────────────────────────
document.getElementById('viewToggle').querySelectorAll('button').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('#viewToggle button').forEach(b => {
            b.classList.remove('active','btn-primary');
            b.classList.add('btn-outline-primary');
        });
        btn.classList.add('active','btn-primary');
        btn.classList.remove('btn-outline-primary');
        setViewport(btn.dataset.view);
    });
});

// ── Feed-mode state machine ────────────────────────────────────────
//   animationPaused=false → live mode    (button "⏸ Pause",   30s polling ON,  sim injections blocked)
//   animationPaused=true  → sim-only mode (button "▶ Resume", 30s polling OFF, sim injections allowed)
// onSimStateChange: sim started → sim-only mode; sim stopped → live mode.
// Page-load syncs from localStorage so navigating back from DataInputFormats works.
let animationPaused = false;

function toggleAnimation() {
    animationPaused = !animationPaused;
    var btn = document.getElementById('btnAnimToggle');
    if (btn) btn.textContent = animationPaused ? '▶ Resume' : '⏸ Pause';
    if (!animationPaused) refreshScene(); // returning to live mode → load fresh live data
}

// ── Sim Data Feed Panel JS ─────────────────────────────────────────────
var _simPanelOpen = false;
function toggleSimPanel() {
    _simPanelOpen = !_simPanelOpen;
    var body = document.getElementById('simFeedBody');
    var tog  = document.getElementById('simFeedToggle');
    if (body) body.style.maxHeight = _simPanelOpen ? '90px' : '0';
    if (tog)  tog.textContent = _simPanelOpen ? '▲' : '▼';
}
function _updateSimPanel(ev, dbStatus) {
    var t   = new Date().toLocaleTimeString('en-US', {hour12:false});
    var spd = (ev.speedMph ?? 0).toFixed(1);
    var lat = (ev.latitude  ?? 0).toFixed(4);
    var lon = (ev.longitude ?? 0).toFixed(4);
    var line = t + '  ·  ' + (ev.vehicleId||'?') + '  ·  '
             + (ev.vehicleCategory || ev.vehicleMode || 'vehicle') + '  ·  ' + spd + ' mph';
    var el = document.getElementById('simFeedLine');
    if (el) { el.style.color = '#d1fae5'; el.textContent = line;
              setTimeout(function(){ el.style.color = '#86efac'; }, 800); }
    function setEl(id, val) { var x = document.getElementById(id); if (x) x.textContent = val || '–'; }
    setEl('sfVehicleId', ev.vehicleId);
    setEl('sfType',      ev.vehicleCategory || ev.vehicleMode || 'vehicle');
    setEl('sfSpeed',     spd + ' mph');
    setEl('sfZone',      ev.zoneId || '–');
    setEl('sfLatLon',    lat + ', ' + lon);
    if (dbStatus !== undefined) {
        var dbEl = document.getElementById('sfDbStatus');
        if (dbEl) { dbEl.textContent = dbStatus;
                    dbEl.style.color = dbStatus.startsWith('✓') ? '#4ade80' : '#fbbf24'; }
    }
    if (!_simPanelOpen) toggleSimPanel();
    var badge = document.getElementById('simFeedBadge');
    if (badge) badge.style.display = '';
}

function onSimStateChange(isRunning) {
    animationPaused = isRunning;
    var btn = document.getElementById('btnAnimToggle');
    if (btn) btn.textContent = isRunning ? '▶ Resume' : '⏸ Pause';
    var badge = document.getElementById('simFeedBadge');
    if (badge) badge.style.display = isRunning ? '' : 'none';
    if (!isRunning) {
        refreshScene();
        if (_simPanelOpen) toggleSimPanel();
        var el = document.getElementById('simFeedLine');
        if (el) { el.style.color = '#475569'; el.textContent = 'Sim stopped — viewing live data.'; }
    }
}

// ── Animate loop ──────────────────────────────────────────────────────
const ROAD_HALF = 680; // wrap boundary along X axis
let tick = 0, camTween = null;
function animate() {
    requestAnimationFrame(animate); tick++;
    if (camTween) camTween();

    // Perspective orbit follows the road (x-axis)
    camP.position.x = -220 + radius * 0.4 * Math.sin(theta * 0.3);
    camP.position.y = Math.max(20, radius * Math.sin(phi));
    camP.position.z = 120 + radius * 0.25 * Math.cos(theta * 0.3);
    camP.lookAt(60, 0, 0);

    // Vehicle forward motion along the road
    if (!animationPaused) {
        vehicleMeshes.forEach(m => {
            const { vx, vz, laneZ, baseY } = m.userData;
            m.position.x += vx;
            // Keep vehicles locked to their lane's Z centre
            m.position.z += (laneZ - m.position.z) * 0.06;
            m.position.y  = baseY;
            // Wrap around at road ends
            if (m.position.x >  ROAD_HALF) m.position.x = -ROAD_HALF;
            if (m.position.x < -ROAD_HALF) m.position.x =  ROAD_HALF;
        });
    }

    const cw = renderer.domElement.clientWidth;
    const ch = renderer.domElement.clientHeight;
    renderer.setSize(cw, ch, false);

    if (currentView === 'split') {
        renderer.setViewport(0, 0, cw*0.42, ch);
        renderer.setScissor(0, 0, cw*0.42, ch);
        renderer.setScissorTest(true);
        renderer.render(scene, camP);
        renderer.setViewport(cw*0.43, 0, cw*0.28, ch);
        renderer.setScissor(cw*0.43, 0, cw*0.28, ch);
        renderer.render(scene, camS);
        renderer.setViewport(cw*0.72, 0, cw*0.28, ch);
        renderer.setScissor(cw*0.72, 0, cw*0.28, ch);
        renderer.render(scene, camT);
        renderer.setScissorTest(false);
    } else {
        renderer.setViewport(0, 0, cw, ch);
        const cam = currentView === 'side' ? camS : currentView === 'top' ? camT : camP;
        if (cam.isPerspectiveCamera) { cam.aspect = cw/ch; cam.updateProjectionMatrix(); }
        renderer.render(scene, cam);
    }
}

// ── Boot — default to top-down traffic view ───────────────────────────
(async () => {
    await refreshScene();
    _tryLoadMapTile(); // load navigation map tile for zone centre
    animate();
    // Activate top-down as default (clearest road/traffic view)
    setViewport('top');
    document.querySelectorAll('#viewToggle button').forEach(b => {
        b.classList.remove('active','btn-primary');
        b.classList.add('btn-outline-primary');
    });
    const topBtn = document.querySelector('#viewToggle [data-view="top"]');
    if (topBtn) { topBtn.classList.add('active','btn-primary'); topBtn.classList.remove('btn-outline-primary'); }
})();

// Bug Fix 3: Gate 30-second auto-refresh when animation is paused
setInterval(function() { if (!animationPaused) refreshScene(); }, 30000);

// ── Live simulation feed ───────────────────────────────────────────────
function _simNorm(evObj, cl) {
    var ev = Object.assign({}, evObj);
    if (cl) {
        ev.vehicleCategory  = cl.category;
        ev.vehicleMode      = cl.domain;
        ev.altitudeMeters   = (cl.altitudeM  != null) ? cl.altitudeM  : (evObj.altitude_m  ?? 0);
        ev.speedMph         = (cl.speedMph   != null) ? cl.speedMph   : (evObj.speed_mph   ?? 0);
        ev.vehicleClassJson = JSON.stringify(cl);
    } else {
        ev.altitudeMeters = evObj.altitude_m  ?? 0;
        ev.speedMph       = evObj.speed_mph   ?? 0;
    }
    ev.latitude  = evObj.latitude  ?? evObj.lat  ?? 32.7767;
    ev.longitude = evObj.longitude ?? evObj.lon  ?? -96.7970;
    ev.vehicleId = evObj.vehicle_id || ('SIM-' + Math.random().toString(36).slice(2,6).toUpperCase());
    ev.eventType = evObj.event_type || 'detection';
    ev.zoneId    = evObj.zone_id    || '';
    return ev;
}

function _simInject(evObj, cl) {
    var ev = _simNorm(evObj, cl);
    var vc = classifyLocal(ev);
    if (vc.domain !== 'ground') return;

    _updateSimPanel(ev, '⏳ saving…');

    // ── Always save to DB + refresh (works in both live and sim-only modes) ──
    fetch('/api/sim/event', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
            vehicleId:      ev.vehicleId,
            highwayId:      HW || '',
            zoneId:         ev.zoneId || selectedZoneId || '',
            vehicleType:    vc.category || null,
            srcType:        'physical',
            isAirFlyCar:    'N',
            speedMph:       ev.speedMph,
            latitude:       ev.latitude,
            longitude:      ev.longitude,
            altitudeMeters: ev.altitudeMeters ?? 0
        })
    }).then(function(r) {
        return r.json().then(function(j) {
            if (r.ok) _updateSimPanel(ev, '✓ saved · id ' + j.id);
            else       _updateSimPanel(ev, '✗ ' + (j.error || r.status));
        });
    }).catch(function(err) {
        _updateSimPanel(ev, '✗ ' + (err.message || 'network error'));
    }).finally(function() {
        refreshScene(); // always refresh — event may already be in DB from SimulationPost
    });

    var lbl = document.getElementById('simLiveLabel');
    if (lbl) { lbl.style.opacity = '1'; setTimeout(function(){ lbl.style.opacity = '0'; }, 2500); }

    if (!animationPaused) return; // camera tween only in sim-only mode
    var startR = radius, startP = phi;
    var targR  = Math.max(18, startR * 0.12);
    var targP  = Math.max(0.15, Math.min(0.55, startP));
    var frames = 0, phase = 'in';
    var FIN = 55, FHOLD = 100, FOUT = 70;
    camTween = function() {
        var t, ease;
        if (phase === 'in') {
            frames++;
            t = Math.min(1, frames / FIN);
            ease = t < 0.5 ? 2*t*t : -1+(4-2*t)*t;
            radius = startR + (targR - startR) * ease;
            phi    = startP + (targP - startP) * ease;
            if (frames >= FIN) { frames = 0; phase = 'hold'; }
        } else if (phase === 'hold') {
            frames++;
            if (frames >= FHOLD) { frames = 0; phase = 'out'; }
        } else {
            frames++;
            t = Math.min(1, frames / FOUT);
            ease = t < 0.5 ? 2*t*t : -1+(4-2*t)*t;
            radius = targR + (startR - targR) * ease;
            phi    = targP + (startP - targP) * ease;
            if (frames >= FOUT) { camTween = null; radius = startR; phi = startP; }
        }
    };
}

// Bug Fix 2: BroadcastChannel — only call onSimStateChange for lifecycle events,
// NOT for every sim_vehicle message (which caused Pause↔Resume flicker)
if (typeof BroadcastChannel !== 'undefined') {
    var _simBc = new BroadcastChannel('airways_sim');
    _simBc.onmessage = function(e) {
        if (!e.data) return;
        if (e.data.type === 'sim_vehicle' && e.data.payload && e.data.srcType !== 'airflycar')
            _simInject(e.data.payload, e.data.classification);
        if (e.data.type === 'sim_started') {
            if (!animationPaused) refreshScene();
            onSimStateChange(true);
        }
        if (e.data.type === 'sim_stopped') onSimStateChange(false);
    };
}

// Bug Fix 4: Separate storage listener for airways_sim_active (sim lifecycle state)
// and airways_sim_last_event (vehicle payloads). Previously mixed → dead sim_started check.
window.addEventListener('storage', function(e) {
    if (e.key === 'airways_sim_active') { onSimStateChange(e.newValue === 'true'); return; }
    if (e.key !== 'airways_sim_last_event' || !e.newValue) return;
    try {
        var msg = JSON.parse(e.newValue);
        if (msg.type === 'sim_vehicle' && msg.payload && msg.srcType !== 'airflycar')
            _simInject(msg.payload, msg.classification);
    } catch(ex) {}
});
// Restore sim feed state from localStorage on page load (handles DataInputFormats navigation)
(function() { if (localStorage.getItem('airways_sim_active') === 'true') onSimStateChange(true); })();
</script>
