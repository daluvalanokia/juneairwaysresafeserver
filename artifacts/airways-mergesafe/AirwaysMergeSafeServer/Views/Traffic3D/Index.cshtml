@model AirwaysMergeSafeServer.ViewModels.Traffic3DViewModel
@{
    ViewData["Title"] = "3D Traffic";
    var zonesJson   = System.Text.Json.JsonSerializer.Serialize(
        Model.Zones.Where(z => z.Latitude.HasValue).Select(z => new {
            zoneId = z.ZoneId, zoneName = z.ZoneName, status = z.Status,
            lat = z.Latitude, lon = z.Longitude,
            altM = z.AltitudeMeters ?? 0, radius = z.GeofenceRadius
        }));
    var sensorsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Sensors.Where(s => s.Latitude.HasValue).Select(s => new {
            deviceId = s.DeviceId, deviceName = s.DeviceName,
            deviceType = s.DeviceType, status = s.Status,
            lat = s.Latitude, lon = s.Longitude,
            altM = s.AltitudeMeters ?? 0
        }));
    var serversJson = System.Text.Json.JsonSerializer.Serialize(
        Model.SwitchServers.Select(s => new {
            serverId   = s.ServerId,   serverName = s.ServerName,
            zoneId     = s.ZoneId,     status     = s.Status,
            ipAddress  = s.IpAddress,  port       = s.Port
        }));
    var hw          = Model.SelectedHighwayId ?? "";
    var zoneCtrLat  = Model.Zones.Where(z => z.Latitude.HasValue).Select(z => z.Latitude!.Value).FirstOrDefault();
    var zoneCtrLon  = Model.Zones.Where(z => z.Longitude.HasValue).Select(z => z.Longitude!.Value).FirstOrDefault();
    if (zoneCtrLat == 0) zoneCtrLat = 32.7767;
    if (zoneCtrLon == 0) zoneCtrLon = -96.7970;
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <h4 class="mb-0">🏗 3D Traffic Scene</h4>
        <small class="text-muted">Ground vehicles · Classification-aware rendering</small>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <select id="hwSel" class="form-select form-select-sm" style="width:190px"
                onchange="location.href='/Traffic3D?highwayId='+this.value">
            @foreach (var h in Model.Highways)
            {
                @if (h.HighwayId == Model.SelectedHighwayId)
                { <option value="@h.HighwayId" selected>@h.Name</option> }
                else
                { <option value="@h.HighwayId">@h.Name</option> }
            }
        </select>
        <!-- Zone dropdown -->
        <select id="t3dZoneSel" class="form-select form-select-sm" style="width:150px"
                onchange="t3dZoneChanged()">
            <option value="">(All Zones)</option>
            @foreach (var z in Model.Zones)
            {
                <option value="@z.ZoneId">@z.ZoneName</option>
            }
        </select>
        <!-- Switch Server dropdown -->
        <select id="t3dServerSel" class="form-select form-select-sm" style="width:160px"
                onchange="t3dServerChanged()">
            <option value="">(All Servers)</option>
            @foreach (var s in Model.SwitchServers)
            {
                <option value="@s.ServerId" data-zone="@(s.ZoneId ?? "")">@s.ServerName</option>
            }
        </select>
        <!-- View-mode toggle -->
        <div class="btn-group btn-group-sm" id="viewToggle">
            <button class="btn btn-primary active"    data-view="perspective" title="Perspective">⬡ 3D</button>
            <button class="btn btn-outline-primary"   data-view="side"        title="Side / Elevation">↕ Side</button>
            <button class="btn btn-outline-primary"   data-view="top"         title="Top / Plan">⊞ Top</button>
            <button class="btn btn-outline-primary"   data-view="split"       title="All three panels">⊟ Split</button>
        </div>
        <a href="/AirScene" class="btn btn-sm btn-outline-warning">🛫 Air Scene</a>
        <button id="btnAnimToggle" class="btn btn-sm btn-outline-warning" onclick="toggleAnimation()">⏸ Pause</button>
        <button class="btn btn-sm btn-outline-success" onclick="refreshScene()">⟳ Live</button>
    </div>
</div>

<!-- ── Sim Data Feed Panel ─────────────────────────────────────────────── -->
<div id="simFeedPanel" style="background:rgba(5,12,5,.93);border:1px solid #1e4a1e;border-radius:6px;
     font-family:monospace;font-size:12px;margin-bottom:6px;overflow:hidden">
    <div onclick="toggleSimPanel()"
         style="padding:5px 10px;cursor:pointer;display:flex;align-items:center;gap:8px;user-select:none">
        <span style="color:#4ade80;font-size:.7rem;font-weight:700;letter-spacing:.05em">📡 SIM FEED</span>
        <span id="simFeedBadge" style="background:#dc2626;color:#fff;font-size:.6rem;font-weight:700;
              padding:1px 6px;border-radius:9px;letter-spacing:.08em;display:none">● LIVE</span>
        <span id="simFeedLine" style="color:#475569;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">
            No sim events yet — start the simulator on Data Input Formats.
        </span>
        <span id="simFeedToggle" style="color:#4ade80;font-size:.65rem;flex-shrink:0">▼</span>
    </div>
    <div id="simFeedBody" style="max-height:0;overflow:hidden;transition:max-height .25s ease">
        <div style="padding:6px 12px 8px;border-top:1px solid #1e4a1e">
            <table style="width:100%;font-size:.68rem;border-collapse:collapse">
                <tr>
                    <td style="color:#4ade80;padding:1px 8px 1px 0;width:18%">Vehicle ID</td>
                    <td id="sfVehicleId" style="color:#d1fae5;width:30%">–</td>
                    <td style="color:#4ade80;padding:1px 8px;width:12%">Type</td>
                    <td id="sfType" style="color:#d1fae5">–</td>
                </tr>
                <tr>
                    <td style="color:#4ade80;padding:1px 8px 1px 0">Speed</td>
                    <td id="sfSpeed" style="color:#d1fae5">–</td>
                    <td style="color:#4ade80;padding:1px 8px">Zone</td>
                    <td id="sfZone" style="color:#d1fae5">–</td>
                </tr>
                <tr>
                    <td style="color:#4ade80;padding:1px 8px 1px 0">Lat / Lon</td>
                    <td id="sfLatLon" colspan="3" style="color:#d1fae5">–</td>
                </tr>
                <tr>
                    <td style="color:#4ade80;padding:1px 8px 1px 0">DB Save</td>
                    <td id="sfDbStatus" colspan="3" style="color:#fbbf24">–</td>
                </tr>
            </table>
        </div>
    </div>
</div>

<!-- ── Scene grid (split / single-panel modes) ────────────────────────── -->
<div id="sceneWrap" style="position:relative;height:520px;background:#1a2f1a;border-radius:8px;overflow:hidden">
    <canvas id="mainCanvas" style="width:100%;height:100%"></canvas>
    <!-- Overlay labels for split mode -->
    <div id="labelA" class="badge bg-secondary position-absolute" style="top:6px;left:6px;display:none">Perspective</div>
    <div id="labelB" class="badge bg-info text-dark position-absolute"    style="top:6px;display:none">Side ↕</div>
    <div id="labelC" class="badge bg-warning text-dark position-absolute" style="top:6px;display:none">Top ⊞</div>
    <div id="simLiveLabel" class="badge bg-success position-absolute"
         style="top:6px;right:6px;font-size:.72rem;opacity:0;transition:opacity .5s ease;pointer-events:none;z-index:10">
        🛰 Live Sim — Vehicle Added
    </div>
</div>

<!-- ── Classification legend + inspector ─────────────────────────────── -->
<div class="row mt-3 g-3">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body py-2 px-3">
                <h6 class="mb-2">🔑 Classification Legend</h6>
                <div class="d-flex flex-wrap gap-2" id="classLegend">
                    <span class="badge rounded-pill px-3 py-2" style="background:#3b82f6">sedan</span>
                    <span class="badge rounded-pill px-3 py-2" style="background:#22c55e">suv</span>
                    <span class="badge rounded-pill px-3 py-2" style="background:#f59e0b;color:#000">truck</span>
                    <span class="badge rounded-pill px-3 py-2" style="background:#a855f7">motorcycle</span>
                    <span class="badge rounded-pill px-3 py-2" style="background:#64748b">van</span>
