@model AirwaysMergeSafeServer.ViewModels.Traffic3DViewModel
@{
    ViewData["Title"] = "3D Traffic";
    var zonesJson   = System.Text.Json.JsonSerializer.Serialize(
        Model.Zones.Where(z => z.Latitude.HasValue).Select(z => new {
            zoneId = z.ZoneId, zoneName = z.ZoneName, status = z.Status,
            lat = z.Latitude, lon = z.Longitude,
            altM = z.AltitudeMeters ?? 0, radius = z.GeofenceRadius
        }));
    var serversJson = System.Text.Json.JsonSerializer.Serialize(
        Model.SwitchServers.Select(s => new {
            serverId = s.ServerId, serverName = s.ServerName,
            zoneId = s.ZoneId, status = s.Status,
            altMin = s.AltitudeMinMeters, altMax = s.AltitudeMaxMeters,
            altWidth = s.AltitudeWidthMeters
        }));
    var sensorsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Sensors.Where(s => s.Latitude.HasValue).Select(s => new {
            deviceId = s.DeviceId, deviceName = s.DeviceName,
            deviceType = s.DeviceType, status = s.Status,
            lat = s.Latitude, lon = s.Longitude,
            altM = s.AltitudeMeters ?? 0
        }));
    var hw = Model.SelectedHighwayId ?? "";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <div>
        <h4 class="mb-0">🏗 3D Traffic Scene</h4>
        <small class="text-muted">Classification-aware rendering · Ground &amp; Air vehicles</small>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <select id="hwSel" class="form-select form-select-sm" style="width:210px"
                onchange="location.href='/Traffic3D?highwayId='+this.value">
            @foreach (var h in Model.Highways)
            {
                @if (h.HighwayId == Model.SelectedHighwayId)
                { <option value="@h.HighwayId" selected>@h.Name</option> }
                else
                { <option value="@h.HighwayId">@h.Name</option> }
            }
        </select>
        <!-- View-mode toggle -->
        <div class="btn-group btn-group-sm" id="viewToggle">
            <button class="btn btn-primary active"    data-view="perspective" title="Perspective">⬡ 3D</button>
            <button class="btn btn-outline-primary"   data-view="side"        title="Side / Elevation">↕ Side</button>
            <button class="btn btn-outline-primary"   data-view="top"         title="Top / Plan">⊞ Top</button>
            <button class="btn btn-outline-primary"   data-view="split"       title="All three panels">⊟ Split</button>
        </div>
        <!-- Domain filter -->
        <div class="btn-group btn-group-sm" id="domainFilter">
            <button class="btn btn-secondary active" data-domain="all"    title="All">All</button>
            <button class="btn btn-outline-info"     data-domain="ground" title="Ground only">🚗</button>
            <button class="btn btn-outline-warning"  data-domain="air"    title="Air only">✈</button>
        </div>
        <a href="/Traffic3D/AirScene" class="btn btn-sm btn-outline-warning">🛫 Air Scene</a>
        <button class="btn btn-sm btn-outline-success" onclick="refreshScene()">⟳ Live</button>
    </div>
</div>

<!-- ── Scene grid (split / single-panel modes) ────────────────────────── -->
<div id="sceneWrap" style="position:relative;height:520px;background:#0a0a14;border-radius:8px;overflow:hidden">
    <canvas id="mainCanvas" style="width:100%;height:100%"></canvas>
    <!-- Overlay labels for split mode -->
    <div id="labelA" class="badge bg-secondary position-absolute" style="top:6px;left:6px;display:none">Perspective</div>
    <div id="labelB" class="badge bg-info text-dark position-absolute"    style="top:6px;display:none">Side ↕</div>
    <div id="labelC" class="badge bg-warning text-dark position-absolute" style="top:6px;display:none">Top ⊞</div>
    <div id="simLiveLabel" class="badge bg-success position-absolute"
         style="top:6px;right:6px;font-size:.72rem;opacity:0;transition:opacity .5s ease;pointer-events:none;z-index:10">
        🛰 Live Sim — Vehicle Added
    </div>
</div>

<!-- ── Classification legend + inspector ─────────────────────────────── -->
<div class="row mt-3 g-3">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body py-2 px-3">
                <h6 class="mb-2">🔑 Classification Legend</h6>
                <div class="d-flex flex-wrap gap-2" id="classLegend">
                    <!-- Ground -->
                    <span class="badge rounded-pill px-3 py-2" style="background:#3b82f6">sedan</span>
                    <span class="badge rounded-pill px-3 py-2" style="background:#22c55e">suv</span>
                    <span class="badge rounded-pill px-3 py-2" style="background:#f59e0b;color:#000">truck</span>
                    <span class="badge rounded-pill px-3 py-2" style="background:#a855f7">motorcycle</span>
                    <span class="badge rounded-pill px-3 py-2" style="background:#64748b">van</span>
                    <span class="badge rounded-pill px-3 py-2 ms-3" style="background:#00bcd4;color:#000">✈ air_urban</span>
                    <span class="badge rounded-pill px-3 py-2" style="background:#ff6b35">✈ air_express</span>
                </div>
                <!-- Stats bar -->
                <div class="d-flex flex-wrap gap-3 mt-2 small text-muted" id="statsRow">
                    <span>Ground: <b id="statGround">–</b></span>
                    <span>Air: <b id="statAir">–</b></span>
                    <span>Zones: <b>@Model.Zones.Count</b></span>
                    <span>Sensors: <b>@Model.Sensors.Count</b></span>
                    <span>Highway: <b>@(Model.SelectedHighwayId ?? "–")</b></span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body py-2 px-3">
                <h6 class="mb-1">🔍 Inspector <small class="text-muted">(click vehicle)</small></h6>
                <div id="inspector" class="text-muted small">No vehicle selected.</div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
/* ══════════════════════════════════════════════════════════════════════
   CLASSIFICATION-AWARE 3D TRAFFIC SCENE
   ══════════════════════════════════════════════════════════════════════
   Algorithm (mirrors VehicleClassifier.cs):
     1. altitude_m > 10  → air   (≤150 = air_urban, >150 = air_express)
     2. vehicle_type field → direct category map
     3. speed_mph heuristic → motorcycle/sedan/suv/truck/van
     4. VehicleClassJson from API overrides all (stored classification)

   Geometry per category (Three.js):
     sedan       → BoxGeometry  1.6×0.8×0.4   colour #3b82f6
     suv         → BoxGeometry  1.9×0.9×0.55  colour #22c55e
     truck       → BoxGeometry  2.4×0.95×0.75 colour #f59e0b
     motorcycle  → CylinderGeom 0.6×0.3       colour #a855f7
     van         → BoxGeometry  2.1×1.0×1.0   colour #64748b
     air_urban   → ConeGeom(inv)0.5            colour #00bcd4
     air_express → Octahedron   0.6            colour #ff6b35

   Views:
     Perspective  – full 3D, orbit controls
     Side (elev.) – orthographic +X → shows altitude stacking
     Top (plan)   – orthographic ↓  → shows lane spread
     Split        – all three in one canvas (left 42%, mid 29%, right 29%)
   ══════════════════════════════════════════════════════════════════════ */

const ALT_SCALE = 0.05;
const XZ_SCALE  = 800;
const HW        = '@hw';

// ── Geometry + colour factory ─────────────────────────────────────────
const CAT_SPEC = {
    sedan:       { color:'#3b82f6', geo:()=>new THREE.BoxGeometry(1.6,0.4,0.8) },
    suv:         { color:'#22c55e', geo:()=>new THREE.BoxGeometry(1.9,0.55,0.9) },
    truck:       { color:'#f59e0b', geo:()=>new THREE.BoxGeometry(2.4,0.75,0.95) },
    motorcycle:  { color:'#a855f7', geo:()=>new THREE.CylinderGeometry(0.15,0.15,0.5,8) },
    van:         { color:'#64748b', geo:()=>new THREE.BoxGeometry(2.1,1.0,1.0) },
    air_urban:   { color:'#00bcd4', geo:()=>new THREE.ConeGeometry(0.5,0.9,6) },
    air_express: { color:'#ff6b35', geo:()=>new THREE.OctahedronGeometry(0.6) },
};
const DEFAULT_SPEC = CAT_SPEC.sedan;

function getSpec(vc) {
    if (!vc) return DEFAULT_SPEC;
    const cat = vc.category || vc.vehicleCategory || 'sedan';
    return CAT_SPEC[cat] || DEFAULT_SPEC;
}

// ── JS-side classifier (mirrors C# VehicleClassifier, used as fallback) ─
function classifyLocal(ev) {
    // Use stored classification if available
    if (ev.vehicleClassJson) {
        try {
            const vc = typeof ev.vehicleClassJson === 'string'
                ? JSON.parse(ev.vehicleClassJson) : ev.vehicleClassJson;
            if (vc && vc.category) return vc;
        } catch(e) {}
    }
    if (ev.vehicleCategory && ev.vehicleMode)
        return { category: ev.vehicleCategory, domain: ev.vehicleMode, color: CAT_SPEC[ev.vehicleCategory]?.color || '#3b82f6' };

    // Step 1: Altitude gate
    const alt = ev.altitudeMeters ?? ev.altitudeM ?? null;
    if (alt !== null && alt > 10)
        return { category: alt <= 150 ? 'air_urban' : 'air_express', domain: 'air',
                 color: alt <= 150 ? '#00bcd4' : '#ff6b35' };

    // Step 3: Speed heuristic
    const s = ev.speedMph;
    let cat = 'sedan';
    if (s !== null && s !== undefined) {
        if (s <= 25) cat = 'motorcycle';
        else if (s <= 55) cat = 'sedan';
        else if (s <= 75) cat = 'suv';
        else if (s <= 90) cat = 'truck';
        else cat = 'van';
    }
    return { category: cat, domain: 'ground', color: CAT_SPEC[cat]?.color || '#3b82f6' };
}

// ── Lat/lon normalisation ─────────────────────────────────────────────
let midLat = 32.75, midLon = -97.0;
function norm(lat, lon) {
    return { x: (lon - midLon) * XZ_SCALE, z: (lat - midLat) * XZ_SCALE };
}

// ── Scene setup ───────────────────────────────────────────────────────
const scene = new THREE.Scene();
scene.background = new THREE.Color(0x0a0a14);
scene.add(new THREE.AmbientLight(0xffffff, 0.45));
const dir = new THREE.DirectionalLight(0xffffff, 0.9);
dir.position.set(60, 200, 80); scene.add(dir);
scene.add(new THREE.GridHelper(500, 50, 0x1a1a2e, 0x111133));

// Static zones
const ZONES = @Html.Raw(zonesJson);
ZONES.forEach(z => {
    if (!z.lat || !z.lon) return;
    const p  = norm(z.lat, z.lon);
    const r  = (z.radius / 20) || 15;
    const cy = new THREE.CylinderGeometry(r, r, 0.2, 32);
    const cm = new THREE.MeshPhongMaterial({
        color: z.status === 'active' ? 0x22c55e : 0xf59e0b,
        transparent: true, opacity: 0.18, depthWrite: false
    });
    const mesh = new THREE.Mesh(cy, cm);
    mesh.position.set(p.x, 0.1 + z.altM * ALT_SCALE, p.z);
    scene.add(mesh);
    // Zone ring
    const ring = new THREE.Mesh(
        new THREE.TorusGeometry(r, 0.15, 8, 48),
        new THREE.MeshPhongMaterial({ color: 0x22c55e, opacity: 0.5, transparent: true })
    );
    ring.rotation.x = Math.PI / 2;
    ring.position.set(p.x, 0.2, p.z);
    scene.add(ring);
});

// Altitude band planes (from SwitchServers)
const SERVERS = @Html.Raw(serversJson);
SERVERS.filter(s => s.altMin && s.altMax).forEach((s, i) => {
    const h   = (s.altMax - s.altMin) * ALT_SCALE;
    const midY = ((s.altMin + s.altMax) / 2) * ALT_SCALE;
    const hue = (i * 137.5) % 360;
    const col = new THREE.Color(`hsl(${hue},70%,55%)`);
    const geo  = new THREE.BoxGeometry((s.altWidth || 30) * ALT_SCALE * 20, h, 300);
    const mat  = new THREE.MeshPhongMaterial({ color: col, transparent: true, opacity: 0.10, depthWrite: false });
    const mesh = new THREE.Mesh(geo, mat);
    mesh.position.set(i * 12 - (SERVERS.length * 6), midY, 0);
    scene.add(mesh);
});

// ── Vehicle mesh management ───────────────────────────────────────────
const vehicleMeshes = [], vehicleData = [];
const raycaster = new THREE.Raycaster();
const mouse2    = new THREE.Vector2();
let domainFilter = 'all';

function buildVehicleMesh(ev) {
    const vc   = classifyLocal(ev);
    const spec = getSpec(vc);
    const geo  = spec.geo();
    const mat  = new THREE.MeshPhongMaterial({ color: new THREE.Color(vc.color || spec.color) });
    const mesh = new THREE.Mesh(geo, mat);

    const p = (ev.latitude && ev.longitude) ? norm(ev.latitude, ev.longitude)
              : { x: (Math.random()-0.5)*180, z: (Math.random()-0.5)*180 };
    const altY = vc.domain === 'air' ? (ev.altitudeMeters || 50) * ALT_SCALE : 0.3;
    mesh.position.set(p.x, altY, p.z);

    // Rotate air vehicles slightly
    if (vc.domain === 'air') mesh.rotation.y = Math.random() * Math.PI * 2;

    mesh.userData = { ev, vc, baseY: altY, idx: vehicleMeshes.length };
    return mesh;
}

function loadEvents(events) {
    vehicleMeshes.forEach(m => { scene.remove(m); m.geometry.dispose(); m.material.dispose(); });
    vehicleMeshes.length = 0; vehicleData.length = 0;

    let gCount = 0, aCount = 0;
    events.forEach(ev => {
        const vc = classifyLocal(ev);
        if (domainFilter !== 'all' && vc.domain !== domainFilter) return;
        const mesh = buildVehicleMesh(ev);
        scene.add(mesh);
        vehicleMeshes.push(mesh);
        vehicleData.push({ ev, vc });
        if (vc.domain === 'air') aCount++; else gCount++;
    });
    document.getElementById('statGround').textContent = gCount;
    document.getElementById('statAir').textContent    = aCount;
}

async function refreshScene() {
    try {
        const r = await fetch(`/api/events/live?highwayId=${HW}&take=100`);
        if (!r.ok) return;
        const evs = await r.json();
        if (evs.length > 0) {
            const lats = evs.filter(e=>e.latitude).map(e=>e.latitude);
            const lons = evs.filter(e=>e.longitude).map(e=>e.longitude);
            if (lats.length) {
                midLat = lats.reduce((a,b)=>a+b,0)/lats.length;
                midLon = lons.reduce((a,b)=>a+b,0)/lons.length;
            }
        }
        loadEvents(evs);
    } catch(e) { console.warn('Scene refresh error:', e); }
}

// ── Camera setup ──────────────────────────────────────────────────────
const canvas = document.getElementById('mainCanvas');
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true });
renderer.setPixelRatio(window.devicePixelRatio);
renderer.setSize(canvas.clientWidth, canvas.clientHeight);

// Perspective cam
const camP = new THREE.PerspectiveCamera(58, canvas.clientWidth/canvas.clientHeight, 0.1, 3000);
camP.position.set(100, 80, 180); camP.lookAt(0, 20, 0);

// Side cam (elevation, orthographic, looking along -X)
const oW = 160, oH = 120;
const camS = new THREE.OrthographicCamera(-oW, oW, oH, -oH, 0.1, 2000);
camS.position.set(500, 0, 0); camS.lookAt(0, 0, 0);

// Top cam (plan, looking straight down)
const camT = new THREE.OrthographicCamera(-oW, oW, oH, -oH, 0.1, 2000);
camT.position.set(0, 600, 0); camT.up.set(0, 0, -1); camT.lookAt(0, 0, 0);

// ── View mode ─────────────────────────────────────────────────────────
let currentView = 'perspective';

function setViewport(view) {
    currentView = view;
    const w = renderer.domElement.clientWidth;
    const h = renderer.domElement.clientHeight;
    // Show/hide split labels
    document.getElementById('labelA').style.display = view === 'split' ? '' : 'none';
    document.getElementById('labelB').style.display = view === 'split' ? '' : 'none';
    document.getElementById('labelC').style.display = view === 'split' ? '' : 'none';
    if (view === 'split') {
        document.getElementById('labelB').style.left = Math.round(w * 0.43) + 'px';
        document.getElementById('labelC').style.left = Math.round(w * 0.72) + 'px';
    }
}

// ── Orbit (perspective) ───────────────────────────────────────────────
let isDrag = false, prevM = {x:0,y:0}, theta = 0.6, phi = 0.5, radius = 280;
canvas.addEventListener('mousedown', e => { isDrag = true; prevM = {x:e.clientX, y:e.clientY}; });
window.addEventListener('mouseup', () => isDrag = false);
window.addEventListener('mousemove', e => {
    if (!isDrag || currentView !== 'perspective') return;
    theta -= (e.clientX - prevM.x) * 0.005;
    phi    = Math.max(0.05, Math.min(1.4, phi - (e.clientY - prevM.y) * 0.005));
    prevM  = { x: e.clientX, y: e.clientY };
});
canvas.addEventListener('wheel', e => { radius = Math.max(60, Math.min(700, radius + e.deltaY * 0.25)); });

// ── Click — vehicle inspector ─────────────────────────────────────────
canvas.addEventListener('click', e => {
    const rect = canvas.getBoundingClientRect();
    mouse2.x =  ((e.clientX - rect.left) / rect.width)  * 2 - 1;
    mouse2.y = -((e.clientY - rect.top)  / rect.height) * 2 + 1;

    let cam = camP;
    if (currentView === 'side') cam = camS;
    else if (currentView === 'top') cam = camT;
    else if (currentView === 'split') {
        const rx = (e.clientX - rect.left) / rect.width;
        cam = rx < 0.42 ? camP : rx < 0.71 ? camS : camT;
    }

    raycaster.setFromCamera(mouse2, cam);
    const hits = raycaster.intersectObjects(vehicleMeshes, false);
    if (hits.length) showInspector(hits[0].object.userData);
});

function showInspector({ ev, vc }) {
    const conf    = vc.confidence ?? vc.Confidence ?? 0;
    const confPct = Math.round(conf * 100);
    const confCls = conf < 0.4 ? 'danger' : conf < 0.65 ? 'warning' : 'success';
    const isAir   = vc.domain === 'air';
    document.getElementById('inspector').innerHTML = `
    <table class="table table-sm table-borderless mb-0 small">
      <tr><td class="text-muted">Vehicle ID</td><td><b>${ev.vehicleId||'—'}</b></td></tr>
      <tr><td class="text-muted">Domain</td><td>
        <span class="badge" style="background:${isAir?'#ff6b35':'#3b82f6'}">${vc.domain}</span>
      </td></tr>
      <tr><td class="text-muted">Category</td><td>
        <span class="badge" style="background:${vc.color||'#64748b'}">${vc.category}</span>
      </td></tr>
      <tr><td class="text-muted">Confidence</td><td>
        <div class="d-flex align-items-center gap-2">
          <div class="progress flex-grow-1" style="height:6px">
            <div class="progress-bar bg-${confCls}" style="width:${confPct}%"></div>
          </div>
          <small>${confPct}%</small>
        </div>
        ${conf < 0.4 ? '<small class="text-danger">⚠ low confidence</small>' : ''}
      </td></tr>
      <tr><td class="text-muted">Speed</td><td>${ev.speedMph!=null?ev.speedMph.toFixed(1)+' mph':'—'}</td></tr>
      <tr><td class="text-muted">Altitude</td><td>${ev.altitudeMeters!=null?ev.altitudeMeters.toFixed(1)+' m':'ground'}</td></tr>
      <tr><td class="text-muted">Event</td><td>${ev.eventType||'—'}</td></tr>
      <tr><td class="text-muted">Zone</td><td>${ev.zoneId||'—'}</td></tr>
    </table>`;
}

// ── Domain filter buttons ─────────────────────────────────────────────
document.getElementById('domainFilter').querySelectorAll('button').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('#domainFilter button').forEach(b => {
            b.classList.remove('active','btn-secondary','btn-info','btn-warning');
            b.classList.add('btn-outline-' + (b.dataset.domain === 'ground' ? 'info' : b.dataset.domain === 'air' ? 'warning' : 'secondary'));
        });
        btn.classList.add('active');
        btn.classList.remove('btn-outline-secondary','btn-outline-info','btn-outline-warning');
        btn.classList.add(btn.dataset.domain === 'ground' ? 'btn-info' : btn.dataset.domain === 'air' ? 'btn-warning' : 'btn-secondary');
        domainFilter = btn.dataset.domain;
        refreshScene();
    });
});

// ── View mode toggle ──────────────────────────────────────────────────
document.getElementById('viewToggle').querySelectorAll('button').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('#viewToggle button').forEach(b => {
            b.classList.remove('active','btn-primary');
            b.classList.add('btn-outline-primary');
        });
        btn.classList.add('active','btn-primary');
        btn.classList.remove('btn-outline-primary');
        setViewport(btn.dataset.view);
    });
});

// ── Animate loop ──────────────────────────────────────────────────────
let tick = 0, camTween = null;
function animate() {
    requestAnimationFrame(animate); tick++;
    if (camTween) camTween();

    // Orbit perspective cam
    camP.position.x = radius * Math.sin(theta) * Math.cos(phi);
    camP.position.y = radius * Math.sin(phi);
    camP.position.z = radius * Math.cos(theta) * Math.cos(phi);
    camP.lookAt(0, 20, 0);

    // Vehicle animation — ground vehicles idle bob; air vehicles gentle drift
    vehicleMeshes.forEach((m, i) => {
        const { vc, baseY } = m.userData;
        if (vc.domain === 'air') {
            m.position.y = baseY + Math.sin(tick * 0.025 + i * 0.8) * 1.5;
            m.rotation.y += 0.005;
        } else {
            m.position.y = baseY + Math.sin(tick * 0.04 + i) * 0.05;
        }
    });

    const cw = renderer.domElement.clientWidth;
    const ch = renderer.domElement.clientHeight;
    renderer.setSize(cw, ch, false);

    if (currentView === 'split') {
        // Panel A — Perspective (left 42%)
        renderer.setViewport(0, 0, cw*0.42, ch);
        renderer.setScissor(0, 0, cw*0.42, ch);
        renderer.setScissorTest(true);
        renderer.render(scene, camP);
        // Panel B — Side (mid 29%)
        renderer.setViewport(cw*0.43, 0, cw*0.28, ch);
        renderer.setScissor(cw*0.43, 0, cw*0.28, ch);
        renderer.render(scene, camS);
        // Panel C — Top (right 29%)
        renderer.setViewport(cw*0.72, 0, cw*0.28, ch);
        renderer.setScissor(cw*0.72, 0, cw*0.28, ch);
        renderer.render(scene, camT);
        renderer.setScissorTest(false);
    } else {
        renderer.setViewport(0, 0, cw, ch);
        const cam = currentView === 'side' ? camS : currentView === 'top' ? camT : camP;
        if (cam.isPerspectiveCamera) { cam.aspect = cw/ch; cam.updateProjectionMatrix(); }
        renderer.render(scene, cam);
    }
}

// ── Boot ──────────────────────────────────────────────────────────────
(async () => {
    await refreshScene();
    animate();
    setViewport('perspective');
})();

// Auto-refresh every 30 s
setInterval(refreshScene, 30000);

// ── Live simulation feed ───────────────────────────────────────────────
// Defined outside BroadcastChannel block so the localStorage 'storage'
// fallback can also call them when the user navigates between pages.
function _simNorm(evObj, cl) {
    var ev = Object.assign({}, evObj);
    if (cl) {
        ev.vehicleCategory  = cl.category;
        ev.vehicleMode      = cl.domain;
        ev.altitudeMeters   = (cl.altitudeM  != null) ? cl.altitudeM  : (evObj.altitude_m  ?? 0);
        ev.speedMph         = (cl.speedMph   != null) ? cl.speedMph   : (evObj.speed_mph   ?? 0);
        ev.vehicleClassJson = JSON.stringify(cl);
    } else {
        ev.altitudeMeters = evObj.altitude_m  ?? 0;
        ev.speedMph       = evObj.speed_mph   ?? 0;
    }
    ev.latitude  = evObj.latitude  ?? evObj.lat  ?? 32.7767;
    ev.longitude = evObj.longitude ?? evObj.lon  ?? -96.7970;
    ev.vehicleId = evObj.vehicle_id || ('SIM-' + Math.random().toString(36).slice(2,6).toUpperCase());
    ev.eventType = evObj.event_type || 'detection';
    ev.zoneId    = evObj.zone_id    || '';
    return ev;
}

function _simInject(evObj, cl) {
    var ev = _simNorm(evObj, cl);
    var vc = classifyLocal(ev);
    if (domainFilter !== 'all' && vc.domain !== domainFilter) return;

    var mesh = buildVehicleMesh(ev);
    scene.add(mesh);
    vehicleMeshes.push(mesh);

    // Update stat counters
    var gEl = document.getElementById('statGround');
    var aEl = document.getElementById('statAir');
    if (vc.domain === 'air') aEl.textContent = (+aEl.textContent||0) + 1;
    else                     gEl.textContent = (+gEl.textContent||0) + 1;

    // Flash overlay label
    var lbl = document.getElementById('simLiveLabel');
    if (lbl) { lbl.style.opacity = '1'; setTimeout(function(){ lbl.style.opacity = '0'; }, 2500); }

    // ── Perspective close-up fly-in ───────────────────────────────
    var startR = radius, startP = phi;
    var targR  = Math.max(18, startR * 0.12);
    var targP  = Math.max(0.15, Math.min(0.55, startP));
    var frames = 0, phase = 'in';
    var FIN = 55, FHOLD = 100, FOUT = 70;
    camTween = function() {
        var t, ease;
        if (phase === 'in') {
            frames++;
            t = Math.min(1, frames / FIN);
            ease = t < 0.5 ? 2*t*t : -1+(4-2*t)*t;
            radius = startR + (targR - startR) * ease;
            phi    = startP + (targP - startP) * ease;
            if (frames >= FIN) { frames = 0; phase = 'hold'; }
        } else if (phase === 'hold') {
            frames++;
            if (frames >= FHOLD) { frames = 0; phase = 'out'; }
        } else {
            frames++;
            t = Math.min(1, frames / FOUT);
            ease = t < 0.5 ? 2*t*t : -1+(4-2*t)*t;
            radius = targR + (startR - targR) * ease;
            phi    = targP + (startP - targP) * ease;
            if (frames >= FOUT) { camTween = null; radius = startR; phi = startP; }
        }
    };
}

// BroadcastChannel — works when both pages are open simultaneously
if (typeof BroadcastChannel !== 'undefined') {
    var _simBc = new BroadcastChannel('airways_sim');
    _simBc.onmessage = function(e) {
        if (!e.data) return;
        // airflycar events are handled exclusively by AirScene
        if (e.data.type === 'sim_vehicle' && e.data.payload && e.data.srcType !== 'airflycar')
            _simInject(e.data.payload, e.data.classification);
        if (e.data.type === 'sim_started') refreshScene();
    };
}

// localStorage fallback — fires via 'storage' event when DataInputFormats
// writes a sim event even after the user has navigated away from that page
window.addEventListener('storage', function(e) {
    if (e.key !== 'airways_sim_last_event' || !e.newValue) return;
    try {
        var msg = JSON.parse(e.newValue);
        // airflycar events are handled exclusively by AirScene
        if (msg.type === 'sim_vehicle' && msg.payload && msg.srcType !== 'airflycar')
            _simInject(msg.payload, msg.classification);
        if (msg.type === 'sim_started') refreshScene();
    } catch(ex) {}
});
</script>
