        '</div>' +
        '<div id="vdBodyFmt" style="padding:10px 12px;max-height:220px;overflow-y:auto"></div>' +
        '<div id="vdBodyRaw" style="display:none;padding:10px 12px;max-height:220px;overflow-y:auto">' +
