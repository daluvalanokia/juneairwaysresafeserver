@model EyewaysMergeSafeServer.ViewModels.DatabaseViewerViewModel
@{ ViewData["Title"] = "Database Viewer"; }

<div class="mss-page-header">
    <div>
        <h2 class="mss-page-title"><i class="bi bi-table me-2"></i>Database Viewer</h2>
        <p class="mss-page-sub">
            Read-only live view of all database tables &nbsp;
            <span class="badge bg-danger" style="font-size:.62rem;vertical-align:middle">
                <i class="bi bi-shield-lock me-1"></i>ADMIN ONLY
            </span>
        </p>
    </div>
    <div class="d-flex gap-2 align-items-center">
        <button class="btn btn-outline-secondary btn-sm" onclick="exportCsv()">
            <i class="bi bi-download me-1"></i>Export CSV
        </button>
        <a href="/DatabaseViewer?table=@Model.SelectedTable&page=@Model.Page"
           class="btn btn-outline-secondary btn-sm" title="Refresh">
            <i class="bi bi-arrow-clockwise"></i>
        </a>
    </div>
</div>

<div class="row g-3">

    @* ── Left: table list ────────────────────────────────────────────────── *@
    <div class="col-md-3 col-xl-2">
        <div class="mss-card h-100">
            <div class="mss-card-header">
                <i class="bi bi-database me-1"></i> Tables
            </div>
            <div class="list-group list-group-flush" style="border-radius:0 0 10px 10px;overflow:hidden">
                @foreach (var (name, count) in Model.TableSummary)
                {
                    bool active = name == Model.SelectedTable;
                    <a href="/DatabaseViewer?table=@name&page=1"
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center text-decoration-none"
                       style="background:@(active ? "rgba(59,130,246,.18)" : "rgba(255,255,255,.03)");
                              color:@(active ? "#e2e8f0" : "#94a3b8");
                              border-color:rgba(255,255,255,.07);
                              border-left:@(active ? "3px solid #3b82f6" : "3px solid transparent");
                              font-size:.78rem;padding:.55rem .85rem">
                        <span class="@(active ? "fw-semibold" : "")">@name</span>
                        <span class="badge @(active ? "bg-primary" : "bg-secondary bg-opacity-50")"
                              style="font-size:.6rem">@count</span>
                    </a>
                }
            </div>
        </div>
    </div>

    @* ── Right: data table ──────────────────────────────────────────────── *@
    <div class="col-md-9 col-xl-10">
        <div class="mss-card">
            <div class="mss-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div class="d-flex align-items-center gap-2">
                    <span class="fw-semibold">@Model.SelectedTable</span>
                    <span class="badge bg-secondary" style="font-size:.62rem">
                        @Model.TotalRows.ToString("N0") rows
                    </span>
                    @if (Model.TotalRows > Model.PageSize)
                    {
                        <span class="text-muted" style="font-size:.72rem">
                            page @Model.Page / @Model.TotalPages
                        </span>
                    }
                </div>
                <input type="text" id="rowSearch"
                       class="form-control form-control-sm"
                       placeholder="Filter visible rows…"
                       style="width:200px;background:#0f1624;border-color:rgba(255,255,255,.18);color:#e2e8f0;font-size:.78rem"
                       oninput="filterRows(this.value)" />
            </div>

            @if (Model.Rows.Any())
            {
                <div class="table-responsive" style="max-height:600px;overflow-y:auto">
                    <table id="dbTable"
                           class="table table-dark table-hover table-sm table-bordered mb-0 font-monospace"
                           style="font-size:.71rem;border-color:rgba(255,255,255,.08)">
                        <thead class="sticky-top" style="background:#0d1321;z-index:2">
                            <tr>
                                <th style="width:38px;color:#475569;font-weight:400">#</th>
                                @foreach (var col in Model.Columns)
                                {
                                    <th class="text-nowrap"
                                        onclick="sortByCol(this)"
                                        style="cursor:pointer;user-select:none;color:#94a3b8;font-weight:500;white-space:nowrap">
                                        @col
                                        <i class="bi bi-arrow-down-up ms-1"
                                           style="font-size:.52rem;opacity:.35"></i>
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody id="dbTableBody">
                            @{ int rowStart = (Model.Page - 1) * Model.PageSize; }
                            @for (int i = 0; i < Model.Rows.Count; i++)
                            {
                                <tr>
                                    <td class="text-muted" style="color:#475569 !important">
                                        @(rowStart + i + 1)
                                    </td>
                                    @foreach (var col in Model.Columns)
                                    {
                                        string val = Model.Rows[i].TryGetValue(col, out var v) ? v : "";
                                        string display = val.Length > 80 ? val[..77] + "…" : val;
                                        string cellStyle = val.Length > 80
                                            ? "max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                                            : "white-space:nowrap";
                                        <td style="@cellStyle" title="@val">@display</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (Model.TotalPages > 1)
                {
                    <div class="d-flex justify-content-between align-items-center px-3 py-2"
                         style="border-top:1px solid rgba(255,255,255,.07)">
                        <span class="text-muted" style="font-size:.75rem">
                            Rows @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, Model.TotalRows))
                            of @Model.TotalRows.ToString("N0")
                        </span>
                        <div class="d-flex gap-1">
                            @if (Model.Page > 1)
                            {
                                <a href="/DatabaseViewer?table=@Model.SelectedTable&page=1"
                                   class="btn btn-outline-secondary btn-sm" title="First">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                                <a href="/DatabaseViewer?table=@Model.SelectedTable&page=@(Model.Page - 1)"
                                   class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            }
                            @for (int p = Math.Max(1, Model.Page - 2); p <= Math.Min(Model.TotalPages, Model.Page + 2); p++)
                            {
                                <a href="/DatabaseViewer?table=@Model.SelectedTable&page=@p"
                                   class="btn btn-sm @(p == Model.Page ? "btn-primary" : "btn-outline-secondary")">
                                    @p
                                </a>
                            }
                            @if (Model.Page < Model.TotalPages)
                            {
                                <a href="/DatabaseViewer?table=@Model.SelectedTable&page=@(Model.Page + 1)"
                                   class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                                <a href="/DatabaseViewer?table=@Model.SelectedTable&page=@Model.TotalPages"
                                   class="btn btn-outline-secondary btn-sm" title="Last">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-2 mb-2 d-block"></i>
                    <div>No records in <strong class="text-white">@Model.SelectedTable</strong></div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
function filterRows(q) {
    var rows = document.querySelectorAll('#dbTableBody tr');
    var lq   = q.toLowerCase();
    rows.forEach(function(r) {
        r.style.display = r.textContent.toLowerCase().includes(lq) ? '' : 'none';
    });
}

function sortByCol(th) {
    var tbody  = document.getElementById('dbTableBody');
    var idx    = th.cellIndex;
    var asc    = th.dataset.sort !== 'asc';
    th.dataset.sort = asc ? 'asc' : 'desc';

    var icon = th.querySelector('i');
    document.querySelectorAll('#dbTable thead th i').forEach(function(i){ i.style.opacity='.35'; });
    if (icon) { icon.style.opacity='1'; icon.className = 'bi ' + (asc ? 'bi-sort-down' : 'bi-sort-up') + ' ms-1'; }

    Array.from(tbody.querySelectorAll('tr'))
        .sort(function(a, b) {
            var av = (a.cells[idx] && a.cells[idx].title) || a.cells[idx]?.textContent?.trim() || '';
            var bv = (b.cells[idx] && b.cells[idx].title) || b.cells[idx]?.textContent?.trim() || '';
            var n  = parseFloat(av) - parseFloat(bv);
            if (!isNaN(n)) return asc ? n : -n;
            return asc ? av.localeCompare(bv) : bv.localeCompare(av);
        })
        .forEach(function(r) { tbody.appendChild(r); });
}

function exportCsv() {
    var table = document.getElementById('dbTable');
    if (!table) return;
    var rows = Array.from(table.querySelectorAll('tr'));
    var csv  = rows.map(function(r) {
        return Array.from(r.querySelectorAll('th,td'))
            .slice(1)
            .map(function(c) {
                var t = (c.getAttribute('title') || c.textContent || '').replace(/"/g, '""');
                return '"' + t + '"';
            }).join(',');
    }).join('\r\n');
    var a   = document.createElement('a');
    a.href  = URL.createObjectURL(new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8' }));
    a.download = '@Model.SelectedTable' + '_page@(Model.Page).csv';
    a.click();
    URL.revokeObjectURL(a.href);
}
</script>
}
