<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>EyewaysMergeSafeServer — @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="mss-body">

@{
    var highways = ViewBag.Highways as List<EyewaysMergeSafeServer.Models.Highway>;
    var selectedHw = ViewBag.SelectedHighwayId as string ?? Context.Session.GetString("HighwayId");
    var currentCtrl = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower();
    var nav = new (string Ctrl, string Icon, string Label)[]
    {
        ("dashboard",         "bi-speedometer2",     "Dashboard"),
        ("settings",          "bi-sign-intersection","Settings / Highways"),
        ("mergezones",        "bi-diagram-2",        "Merge Zones"),
        ("switchservers",     "bi-hdd-network",      "Switch Servers"),
        ("sensors",           "bi-camera-video",     "Sensor Devices"),
        ("triangulation",     "bi-triangle",         "Triangulation"),
        ("events",            "bi-activity",         "Vehicle Events"),
        ("traffic3d",         "bi-badge-3d",         "3D Traffic"),
        ("vehicles",          "bi-car-front",        "Vehicle Registry"),
        ("datainputformats",  "bi-plug",             "Data Input Formats"),
        ("users",             "bi-people",           "Users"),
        ("home",              "bi-info-circle",      "About / System Info"),
    };
}

<nav class="mss-sidebar" id="sidebar">
    <div class="mss-brand">
        <div class="mss-brand-icon"><i class="bi bi-broadcast-pin"></i></div>
        <span class="mss-brand-name">EyewaysMSS</span>
    </div>
    <div class="mss-nav">
        @foreach (var item in nav)
        {
            var active = currentCtrl == item.Ctrl ? "active" : "";
            <a href="/@(item.Ctrl == "dashboard" ? "Dashboard" : item.Ctrl == "mergezones" ? "MergeZones" : item.Ctrl == "switchservers" ? "SwitchServers" : item.Ctrl == "traffic3d" ? "Traffic3D" : item.Ctrl == "datainputformats" ? "DataInputFormats" : char.ToUpper(item.Ctrl[0]) + item.Ctrl.Substring(1))"
               class="mss-nav-item @active">
                <i class="bi @item.Icon mss-nav-icon"></i>
                <span>@item.Label</span>
            </a>
        }
    @if (Context.Session.GetString("UserType") == "admin")
    {
        <a href="/DatabaseViewer"
           class="mss-nav-item @(currentCtrl == "databaseviewer" ? "active" : "")">
            <i class="bi bi-table mss-nav-icon"></i>
            <span>Database Viewer</span>
        </a>
    }
    </div>
    <div class="mss-sidebar-footer">
        <a href="/Portal/Logout" class="mss-nav-item">
            <i class="bi bi-box-arrow-left mss-nav-icon"></i>
            <span>Sign Out</span>
        </a>
    </div>
</nav>

<main class="mss-main">
    <div class="mss-topbar">
        <button class="mss-sidebar-toggle d-md-none" id="sidebarToggle" aria-label="Toggle sidebar">
            <i class="bi bi-list fs-5"></i>
        </button>
        <div class="mss-live-dot"></div>
        <span class="mss-live-label">SYSTEM LIVE</span>
        <span class="text-muted small ms-2 d-none d-md-inline" id="liveClock"></span>

        @if (highways != null && highways.Any())
        {
            <form method="get" action="@("/" + (currentCtrl == "dashboard" ? "Dashboard" : currentCtrl == "mergezones" ? "MergeZones" : currentCtrl == "switchservers" ? "SwitchServers" : currentCtrl == "traffic3d" ? "Traffic3D" : currentCtrl == "datainputformats" ? "DataInputFormats" : char.ToUpper((currentCtrl ?? "d")[0]) + (currentCtrl ?? "dashboard").Substring(1)))" class="ms-auto d-flex align-items-center gap-2">
                <i class="bi bi-sign-intersection text-muted"></i>
                <select name="highwayId" class="form-select form-select-sm mss-hw-select" onchange="this.form.submit()" style="min-width:200px">
                    @foreach (var hw in highways)
                    {
                        <option value="@hw.HighwayId" selected="@(selectedHw == hw.HighwayId ? "selected" : null)">
                            @hw.Name
                        </option>
                    }
                </select>
            </form>
        }
        else
        {
            <span class="ms-auto text-muted small">@(Context.Session.GetString("FullName") ?? "Guest")</span>
        }
    </div>

    <div class="mss-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                <i class="bi bi-check-circle me-1"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>
<script>startLiveClock('liveClock');</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
