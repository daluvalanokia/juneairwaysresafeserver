modules = ["nodejs-24", "dotnet-8.0", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AirwaysMergeSafeServer"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AirwaysMergeSafeClient"

[[workflows.workflow]]
name = "AirwaysMergeSafeServer"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3000 dotnet run --project artifacts/airways-mergesafe/AirwaysMergeSafeServer/AirwaysMergeSafeServer.csproj"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "AirwaysMergeSafeClient"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 dotnet run --project artifacts/airwaysresafeclient/AirwaysMergeSafeClient/AirwaysMergeSafeClient.csproj"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3002

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[nix]
channel = "stable-25_05"
